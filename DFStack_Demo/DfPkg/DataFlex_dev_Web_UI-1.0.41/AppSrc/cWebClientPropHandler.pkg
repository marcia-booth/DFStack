Use cWebBasePropHandler.pkg


// Handler for client-side properties { WebProperty=Client } }. The base class contains the logic to 
// store them in memory. This class implements the hooks triggered by cWebApp to pass them on when
// a request comes in and to return the changed properties when the request goes out.
//

{ ClassLibrary=WebApp }
{ Visibility=Private }
Class cWebClientPropHandler is a cWebBasePropHandler
    
    Procedure Construct_Object
        Forward Send Construct_Object

    End_Procedure
    
    //
    // Triggered by the cWebApp class when a new request comes in passing in the web properties
    // from the client.
    // 
    // Params:
    //      aSyncProps      Is the set of web properties from the client
    //      aAdvSyncProps   Advanced web properties from the client.
    //
    { Visibility=Private }
    Procedure InitializeCall tWebSyncProps[] aSyncProps tWebAdvSyncProp[] aAdvSyncProps
        Send InitializeSyncProps aSyncProps aAdvSyncProps
        
        Forward Send InitializeCall aSyncProps aAdvSyncProps
    End_Procedure
    
    //
    // Triggered when the processing of a request is finished. The arrays passed by references are
    // filled with properties that need to be stored (updated) on the client.
    //
    { Visibility=Private }
    Procedure FinishedCall tWebSyncProps[] ByRef aChangedSyncProps tWebAdvSyncProp[] ByRef aChangedAdvSyncProps
        // Returns the set of web properties that were changed during the AJAX call.
        Integer iObject iSize iTo iProp icProp iCount iPropIndex iStoreIndex
        
        // Iterate the changed props array and build the aChangedSyncProps array....
        Move 0 to iCount
        Get piSize to iSize
        Get piStoreIndex to iStoreIndex
        
        For iObject from 0 to (iSize - 1)
            If (gaSyncChangedProps[iStoreIndex][iObject].bContainsChanges) Begin
                // Add the object reference....
                Move gaSyncProps[iStoreIndex][iObject].sO to aChangedSyncProps[iCount].sO
                
                // Iterate the changed properties....
                Move (SizeOfArray(gaSyncChangedProps[iStoreIndex][iObject].aiIndex)) to icProp
                
                For iProp from 0 to (icProp - 1)
                    Move gaSyncChangedProps[iStoreIndex][iObject].aiIndex[iProp] to iPropIndex
                    Move gaSyncProps[iStoreIndex][iObject].aP[iPropIndex].sN to aChangedSyncProps[iCount].aP[iProp].sN
                    Move gaSyncProps[iStoreIndex][iObject].aP[iPropIndex].sV to aChangedSyncProps[iCount].aP[iProp].sV
                Loop
                
                Increment iCount
            End
        Loop
        
        Move 0 to iCount
        Move (SizeOfArray(gaAdvSyncProps[iStoreIndex]) -1) to iTo
        For iProp from 0 to iTo
            If (gaAdvSyncProps[iStoreIndex][iProp].bChanged) Begin
                //  Serialize when needed (this is basically always needed for changed properties...)
                Move gaAdvSyncProps[iStoreIndex][iProp].tSyncProp to aChangedAdvSyncProps[iCount]
                
                If (gaAdvSyncProps[iStoreIndex][iProp].bDeserialized) Begin
                    ValueTreeSerializeParameter gaAdvSyncProps[iStoreIndex][iProp].tSvrProp.vV to aChangedAdvSyncProps[iCount].tV
                End
                
                
                Increment iCount
            End
        Loop
        
        Forward Send FinishedCall (&aChangedSyncProps) (&aChangedAdvSyncProps)
    End_Procedure

    
    //
    // Special logic for when a view is loaded. When loading a view the client can already have web
    // properties being webset and they are passed to the server. This function makes sure they are
    // passed back to client as if they where just set by marking all of the properties of the 
    // passed view as changed.
    //
    { Visibility=Private }
    Procedure ProcessLoadViewClientSyncProps Handle hoView
        // Analyses all of the sync properties passed in the request and stored in gaSyncProps. If any of these properties belong to
        // the passed hoView object or a child of hoView, then they are transferred to gaSyncChangedProps. This has the effect of
        // marking the property as changed during the AJAX Call so the values will be sent back to the client.
        //
        // This is used by LoadView to ensure that any cached sync property values of the loaded view that were passed to the server
        // will be passed back to the client so that the client will consider them to have been WebSet during the call and will apply
        // the property changes. This forms part of our support for caching WebSet property changes of views that have never been
        // loaded on the client.
        Integer iObject icObject iTo iStoreIndex
        Integer iProperty   icProperty
        Handle hoObject hoWebNeighborhood
        
        Get piStoreIndex to iStoreIndex
        
        // Iterate the web properties. We are looking for objects that match hoView or are
        // child objects of hoView....
        Get piSize to icObject
        
        For iObject from 0 to (icObject - 1)
            Get phoWebNeighborhood of gaSyncObjectHandles[iStoreIndex][iObject] to hoWebNeighborhood
            
            If (hoWebNeighborhood = hoView) Begin
                // Mark all web properties of this object as changed....
                Move True to gaSyncChangedProps[iStoreIndex][iObject].bContainsChanges     // Mark the object as changed
                
                // Iterate the properties of this object....
                Move (SizeOfArray(gaSyncProps[iStoreIndex][iObject].aP)) to icProperty
                
                For iProperty from 0 to (icProperty - 1)
                    Move iProperty to gaSyncChangedProps[iStoreIndex][iObject].aiIndex[iProperty]
                Loop
            End
        Loop
        
        
        //  Iterate all advanced web properties to mark them as changed as well
        Move (SizeOfArray(gaAdvSyncProps[iStoreIndex]) - 1) to iTo
        For iProperty from 0 to iTo
            Get phoWebNeighborhood of gaAdvSyncProps[iStoreIndex][iProperty].hoObj to hoWebNeighborhood
            If (hoWebNeighborhood = hoView) Begin
                Move True to gaAdvSyncProps[iStoreIndex][iProperty].bChanged
            End
            
        Loop
    End_Procedure


    //
    // Augments the initialization with the logic for advanced sync props. These are serialized to 
    // a value tree when sent to the client (which doesn't happen for server props) and they are 
    // not deserialized until a webget is performed.
    //
    { Visibility=Private }
    Procedure InitializeSyncProps tWebSyncProps[] aSyncProps tWebAdvSyncProp[] aAdvSyncProps
        Integer iSize iProp iStoreIndex
        Handle hoLocator
        
        Get piStoreIndex to iStoreIndex
        Get phoWebControlLocator to hoLocator
        
        //  Initialize the advanced property cache
        Move (SizeOfArray(aAdvSyncProps)) to iSize
        Move (ResizeArray(gaAdvSyncProps[iStoreIndex], 0)) to gaAdvSyncProps[iStoreIndex]   //  Clear it just to be sure
        Move (ResizeArray(gaAdvSyncProps[iStoreIndex], iSize)) to gaAdvSyncProps[iStoreIndex]
        
        For iProp from 0 to (iSize - 1)
            Get FindWebObject of hoLocator aAdvSyncProps[iProp].sO to gaAdvSyncProps[iStoreIndex][iProp].hoObj
            Move False                  to gaAdvSyncProps[iStoreIndex][iProp].bChanged
            Move False                  to gaAdvSyncProps[iStoreIndex][iProp].bDeserialized
            Move 0                      to gaAdvSyncProps[iStoreIndex][iProp].tSvrProp.vV
            Move aAdvSyncProps[iProp]   to gaAdvSyncProps[iStoreIndex][iProp].tSyncProp
        Loop
        
        Forward Send InitializeSyncProps aSyncProps
    End_Procedure
    
    //
    //  Search for an advanced web property in the advanced web properties array.
    //
    { Visibility=Private }
    Function FindAdvPropCache Handle hoObj String sPropName Returns Integer
        Integer iTo iCur iStoreIndex
        
        Get piStoreIndex to iStoreIndex
        
        Move (Uppercase(sPropName)) to sPropName
        Move (SizeOfArray(gaAdvSyncProps[iStoreIndex]) - 1) to iTo
        For iCur from 0 to iTo
            If (gaAdvSyncProps[iStoreIndex][iCur].hoObj = hoObj and Uppercase(gaAdvSyncProps[iStoreIndex][iCur].tSyncProp.sP) = sPropName) Begin
                Function_Return iCur
            End
        Loop
        
        Function_Return -1
    End_Function
    
    Procedure End_Construct_Object
        Forward Send End_Construct_Object

    End_Procedure

End_Class


Class cWebLocalClientPropHandler is a cWebClientPropHandler
    //
    // Called when a request is finished. Marks the handler as inactive.
    //
    { Visibility=Private }
    Procedure FinishedCall tWebSyncProps[] ByRef aChangedSyncProps tWebAdvSyncProp[] ByRef aChangedAdvSyncProps
        Forward Send FinishedCall (&aChangedSyncProps) (&aChangedAdvSyncProps)
        
        Set pbActive to True
    End_Procedure
    
End_Class