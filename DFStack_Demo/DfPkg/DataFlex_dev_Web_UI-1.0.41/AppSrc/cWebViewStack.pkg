    // Returns the view handle of the top of stack. Returns 0 if the Stack is empty.
    // See also InvokingViewHandle.
    Function TopViewHandle Returns Handle
        Integer iTop
        Handle hoView
        tWebViewInfo[] aViewStack

        // Update the stack
        WebGet paViewStack to aViewStack
        Move (SizeOfArray(aViewStack)) to iTop
            
        If (iTop = 0) Begin
            Function_Return C_WebUnresolvedObject
        End
        Else Begin
            Get WebObjectByName aViewStack[iTop-1].sViewName to hoView
            Function_Return hoView
        End
    End_Function
    
    
    // Updates the Should Save value of the top view in the view stack
    { Visibility=Private }
    Procedure UpdateShouldSave
        Integer iTop
        Handle hoView hoMain_DD
        tWebViewInfo[] aViewStack

        // Update the stack
        //Send DeserializeViewStack
        WebGet paViewStack to aViewStack
        Move (SizeOfArray(aViewStack)) to iTop
            
        If (iTop > 0) Begin
            Get WebObjectByName aViewStack[iTop-1].sViewName to hoView
            Get IsViewChanged of hoView to aViewStack[iTop-1].bShouldSave
            WebSet paViewStack to aViewStack
        End
    End_Procedure
    
    // dynamically change the breadcrumb caption for a view
    { Visibility=Private }
    Procedure SetCaption Handle hoView String sCaption
        tWebViewInfo[] aViewStack
        Integer iIndex
        Get GetViewIndex hoView to iIndex
        If (iIndex>=0) Begin
            WebGet paViewStack to aViewStack 
            Move sCaption to aViewStack[iIndex].sCaption
            WebSet paViewStack to aViewStack 
            Send NotifyClients    // Notify the view stack clients of this change
        End
    End_Procedure

    // get breadcrumb caption for this view
    { Visibility=Private }
    Function GetCaption Handle hoView Returns String
        tWebViewInfo[] aViewStack
        Integer iIndex
        Get GetViewIndex hoView to iIndex
        If (iIndex>=0) Begin
            WebGet paViewStack to aViewStack 
            Function_Return aViewStack[iIndex].sCaption
        End
    End_Function
    
    // dynamically change the "header" caption for a view
    { Visibility=Private }
    Procedure SetHeaderCaption Handle hoView String sCaption
        tWebViewInfo[] aViewStack
        Integer iIndex
        Get GetViewIndex hoView to iIndex
        If (iIndex>=0) Begin
            WebGet paViewStack to aViewStack 
            Move sCaption to aViewStack[iIndex].sHeaderCaption
            WebSet paViewStack to aViewStack 
            Send NotifyClients    // Notify the view stack clients of this change
        End
    End_Procedure

    // get header caption for this view
    { Visibility=Private }
    Function GetHeaderCaption Handle hoView Returns String
        tWebViewInfo[] aViewStack
        Integer iIndex
        Get GetViewIndex hoView to iIndex
        If (iIndex>=0) Begin
            WebGet paViewStack to aViewStack 
            Function_Return aViewStack[iIndex].sHeaderCaption
        End
    End_Function

    // Send this to the stack view to Navigate Back down the View Stack to this view.
    // The target view can be in any position in the current view stack, but 
    // it must belong to the current view stack.
    //
    // Each view in the view stack, above the target view, will be tested for
    // data loss (pending saves). If one of the higher views requires a save
    // then it will be activated instead and the "save changes" message will
    // be shown.
    //
    // Typically, this message will be called by a breadcrumb navigation control.
    //
    { Visibility=Private }
    Procedure NavigateBack Handle hoTargetView Boolean bUnconditional
        Handle hoView hoInvokingView hoTopView  
        Integer iIndex
        Boolean bTopChanged
        Integer iStackViews
        tWebViewInfo[] aViewStack
        
        Get TopViewHandle to hoTopView
        If not hoTopView Begin
            Procedure_Return
        End
        
        Get GetViewIndex hoTargetView to iIndex
        If (iIndex=-1) Begin
            Error DFERR_PROGRAM "Target view not in view stack"
            Procedure_Return
        End

        If bUnconditional Begin
            Move hoTargetView to hoView
        End
        Else Begin
            Get InvokingViewHandle to hoInvokingView
    
            If (hoTargetView = hoInvokingView) Begin
                Send NavigateCancel of hoTopView
                Procedure_Return
            End
    
            // If we are not the current top then make sure we are not popping off
            // any views that have pending changes (should save)...
            Get IsViewChanged of hoTopView to bTopChanged
            Get CanCloseViews hoTargetView True to hoView
            If (hoView = hoTargetView and bTopChanged) Begin
               Send NavigateCancelTo of hoTopView hoView 
               Procedure_Return
            End
            Else If (bTopChanged) Begin
               Move hoTopView to hoView 
            End
    
            If (hoView <> hoTargetView) Begin
                Send CantCloseChangedViewError
            End
        End
        // finish the navigation back to the view
        If (hoView <> hoTopView) Begin
            Send NavigateBackToHere of hoView True 0
        End
    End_Procedure

    // navigate back to named view.
    { Visibility=Private }
    Procedure NavigateBackByName String sViewName
        Handle hoView hoTopView
        If (sViewName <> "") Begin
            Get WebObjectByName sViewName to hoView
            Get TopViewHandle to hoTopView
            If (hoView > 0 and hoView <> hoTopView) Begin
                Send NavigateBack hoView False
            End
        End
    End_Procedure
    
    // this can be augmented to create a custom message
    { Visibility=Private }
    Function CantCloseErrorText Returns String
       Function_Return C_$Cannot_Close_Changed_Web_View
    End_Function
    
    { Visibility=Private } 
    Procedure CantCloseChangedViewError
       String sError
       Get CantCloseErrorText to sError
       If (sError<>"") Begin
           Send UserError sError
       End
    End_Procedure

    Procedure End_Construct_Object
        Forward Send End_Construct_Object
    End_Procedure
End_Class
