Use cWebColumnCheckbox.pkg

{ HelpTopic=cWebColumnSelectionIndicator }
Class cWebColumnSelectionIndicator is a cWebColumnCheckbox
    Procedure Construct_Object
        Forward Send Construct_Object
        
        Set psJSClass to "df.WebColumnSelectionIndicator"
        
        {WebProperty=Client}
        { Category="Behavior" } 
        Property Boolean pbSelectAllCheckbox False
    End_Procedure
End_Class