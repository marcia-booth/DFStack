        Move Trans                  to aTranslations[-1]
        
        Move "error_title_client"   to Trans.sN
        Move C_$UnhandledClientProgramError to Trans.sV
        Move Trans                  to aTranslations[-1]
        
        Move "err_entry_required"   to Trans.sN
        If (ghoErrorHandler > 0) ;
            Get Error_Description of ghoErrorHandler DFERR_ENTRY_REQUIRED "" to Trans.sV
        Move Trans                  to aTranslations[-1]
        
        Move "err_enter_valid_date"   to Trans.sN
        If (ghoErrorHandler > 0) ;
            Get Error_Description of ghoErrorHandler DFERR_ENTER_VALID_DATE "" to Trans.sV
        Move Trans                  to aTranslations[-1]
        
        Move "no_file_selected"     to Trans.sN
