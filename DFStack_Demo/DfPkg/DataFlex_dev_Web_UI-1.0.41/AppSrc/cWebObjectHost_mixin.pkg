        Move Trans                  to aTranslations[-1]
        
        Move "file_drop"            to Trans.sN
        Move C_$FileDrop            to Trans.sV
        Move Trans                  to aTranslations[-1]
        
        Move "file_cap_uploading"   to Trans.sN
        Move C_$FileUploading       to Trans.sV
        Move Trans                  to aTranslations[-1]
        
        Move "file_remain"          to Trans.sN
        Move C_$FileRemaining       to Trans.sV
        Move Trans                  to aTranslations[-1]
        
        Move "files"                to Trans.sN
        Move C_$Files               to Trans.sV
        Move Trans                  to aTranslations[-1]
        
        Move "file"                 to Trans.sN
        Move C_$FileLabel           to Trans.sV
        Move Trans                  to aTranslations[-1]
        
        Move "confirm"              to Trans.sN
        Move C_$Confirm             to Trans.sV
        Move Trans                  to aTranslations[-1]
        
        Move "weblist_HeaderMenuRestoreMenuName"    to Trans.sN
        Move C_$WebListHeaderMenuRestoreMenuName    to Trans.sV
        Move Trans                                  to aTranslations[-1]
        
        Move "weblist_HeaderMenuSelectorMenuName"   to Trans.sN
        Move C_$WebListHeaderMenuSelectorMenuName   to Trans.sV
        Move Trans                                  to aTranslations[-1]
        
        Move "rows"                                 to Trans.sN
        Move C_$WebMultiSelectListRows              to Trans.sV
        Move Trans                                  to aTranslations[-1]
        
        Move "weblist_GroupColumns"         to Trans.sN
        Move C_$WebListGrpTitle             to Trans.sV
        Move Trans                          to aTranslations[-1]
        
        Move "weblist_AddGroup"             to Trans.sN
        Move C_$WebListGrpAdd               to Trans.sV
        Move Trans                          to aTranslations[-1]
        
        Move "weblist_AddSubGroup"          to Trans.sN
        Move C_$WebListGrpAddSub            to Trans.sV
        Move Trans                          to aTranslations[-1]
        
        Move "weblist_SelectGroupColumn"    to Trans.sN
        Move C_$WebListGrpGroupSelect       to Trans.sV
        Move Trans                          to aTranslations[-1]
        
        Move "weblist_DragRearrange"        to Trans.sN
        Move C_$WebListGrpDragRearrange     to Trans.sV
        Move Trans                          to aTranslations[-1]
        
        Move "weblist_SwitchSort"           to Trans.sN
        Move C_$WebListGrpSwitchSort        to Trans.sV
        Move Trans                          to aTranslations[-1]
        
        Move "weblist_RemoveGroup"          to Trans.sN
        Move C_$WebListGrpRemove            to Trans.sV
        Move Trans                          to aTranslations[-1]
        
        //  WebWidgetContainer
        Move "webwidgetcon_ToggleEdit"      to Trans.sN
        Move C_$WebWidgetConToggleEdit      to Trans.sV
        Move Trans                          to aTranslations[-1]
        
        Move "webwidgetcon_ResetConfig"     to Trans.sN
        Move C_$WebWidgetConResetConfig     to Trans.sV
        Move Trans                          to aTranslations[-1]
        
        Move "webwidgetcon_SaveEdits"       to Trans.sN
        Move C_$WebWidgetConSaveEdits       to Trans.sV
        Move Trans                          to aTranslations[-1]
        
        Move "webwidgetcon_CancelEdits"     to Trans.sN
        Move C_$WebWidgetConCancelEdits     to Trans.sV
        Move Trans                          to aTranslations[-1]
        
        //  WebWidget 
        Move "webwidget_Drag"               to Trans.sN
        Move C_$WebWidget_Drag              to Trans.sV
        Move Trans                          to aTranslations[-1]
             
        Move "webwidget_Config"             to Trans.sN
        Move C_$WebWidget_Config            to Trans.sV
        Move Trans                          to aTranslations[-1]
        
        Move "webwidget_Remove"             to Trans.sN
        Move C_$WebWidget_Remove            to Trans.sV
        Move Trans                          to aTranslations[-1]
        
        Move "webwidget_Resize"             to Trans.sN
        Move C_$WebWidget_Resize            to Trans.sV
        Move Trans                          to aTranslations[-1]
        
        
        Function_Return aTranslations       
    End_Function

    // Called as part of the initialization process before OnLoad is triggered. Gives the 
    // application a chance to store the locales of the client and use them later.
    //
    // Params:
    //      sBrowserLanguage             Language as reported by the browser (like "en-US" or "nl-NL").
    //      iBrowserTimezoneOffsetMins   Timezone offset in minutes as reported by the browser. Usually 
    //                                  considers daylight saving time.
    { MethodType=Event }
    Procedure OnInitializeLocales String sBrowserLanguage Integer iBrowserTimezoneOffsetMins
    End_Procedure
    
    // Called as the last step of the initialization of the webapp just before pbInitWebApp becomes
    // false. At this point the web property system should be initialized and configuration options
    // (like pbLocking of phoServerPropStore) can be set here.
    { MethodType=Event }
    Procedure OnPostInitialize
    End_Procedure
    
    // Called during the creation of the webapp object. For FlexTron this is called later to 
    // synchronize better with windows controls. Note that Attach_Deo_To_Server should be broadcasted
    // before this method is called.
    { Visibility=Private }
    Procedure FinishWebObjectInitialize
        Broadcast Recursive Send AfterAttachDDO         // Received by all data-bound DEOs after DDO properties are applied (or not).
        
        Send OnPostInitialize
        
        // Indicate that we are finished initializing the WebApp. This comes
        // after Forward Send End_Construct_Object to make sure we are fully
        // protected.
        Set pbInitWebApp to False
    End_Procedure
    
    { Visibility=Private }
    Procedure End_Construct_cWebObjectHost_mixin
        WebPublishFunction LoadWebApp
    End_Procedure   
End_Class