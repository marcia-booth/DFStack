Use cWebMenuItem.pkg

// Menu items for WebApp Request_Delete
{ HelpTopic=cWebMenuDelete }
Class cWebMenuDelete is a cWebMenuItem
    
    Procedure Construct_Object
        Forward Send Construct_Object
        Set psCaption to C_$CaptionDelete
        Set psToolTip to C_$ToolTipDelete
        Set psCSSClass to "WebDeleteMenuItem"
    End_Procedure

    Procedure OnClick
        Handle hoFocus
        Get DEOFocusObject to hoFocus
        If hoFocus Begin
            Send Request_Delete of hoFocus
        End
    End_Procedure
         
End_Class 
                
