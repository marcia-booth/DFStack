Use cWebMenuItem.pkg

// Menu items for WebApp Request_Find GT
{ HelpTopic=cWebMenuFindNext }
Class cWebMenuFindNext is a cWebMenuItem
    
    Procedure Construct_Object
        Forward Send Construct_Object
        Set psCaption to C_$CaptionFindGT
        Set psCSSClass to "WebNextMenuItem"
        Set psToolTip to C_$ToolTipFindGT
    End_Procedure

    Procedure OnClick
        Handle hoFocus
        Get DEOControlFocusObject to hoFocus
        If hoFocus Begin
            Send Request_Find of hoFocus  GT
        End
    End_Procedure
         
End_Class 

