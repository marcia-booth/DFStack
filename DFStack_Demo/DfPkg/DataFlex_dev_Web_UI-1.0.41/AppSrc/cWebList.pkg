Use cWebBaseControl.pkg  
Use tWebRow.pkg
Use tWebNavigateData.pkg
Use cJsonObject.pkg

Use cWebContextMenu.pkg
Use cWebMenuColumnList.pkg
Use cWebMenuColumnRestorer.pkg
Use cWebMenuGroupingSelector.pkg
Use cWebColumn_mixin.pkg

Use SoapConstants.pkg
Use WebUIConstants.pkg
Use NameValuePairFunctions.pkg

Struct tWebColumnLayout
    String sObjName
    Boolean bFixed
    Number iWidth
    Integer iPosition
    Boolean bHidden
End_Struct

// Container class for client side list.
{ DesignerClass=cDTCWebGrid }
{ DesignerJSClass=df.WebList }
{ CompositeClass=cWebColumn }
{ HelpTopic=cWebList }
{ Navigable=OnRowClick }
Class cWebList is a cWebBaseControl
    
    Procedure Construct_Object
        Forward Send Construct_Object
        
        { Category="Behavior" }
        Property Integer piOrdering -1                // initial ordering index see also Function Ordering
        { Category="Behavior" }
        Property Integer piPageSize 80                // Max number of rows to send to the client at a time. 0 = load all available rows
        
        // should columns adjust their pbEnabled based on the DDO binding or should it be static.
        // Normally only grids should be dynamic. This property is queried by cWebColumn objects.
        { Category="Behavior" }
        Property Boolean pbColumnsEnabledStatic True

        { Category="Data" }
        { EnumList="rfmFindAll, rfmFindMainOnly, rfmFindMainSuper, rfmFindNone, rfmFindParentOnly" }
        Property Integer peRequestFindMode rfmFindAll
        
        { WebProperty=Client } 
        { Category="Data" }
        Property Boolean pbDataAware True             // Set True if Grid Columns use data binding to DDO. False if there should be no DDO connection.

        { WebProperty=Client } 
        { EnumList="gtAutomatic, gtAllData, gtManual" }
        { Category="Data" }
        Property Integer peDbGridType gtAutomatic           // If set to true, data is static and load just once. Only used with pbDataAware=T.
        
        { WebProperty=Client }
        { EnumList="grpDisabled, grpCustom, grpAutomatic" }
        { Category="Behavior" }
        Property Integer peGrouping grpDisabled
        
        { WebProperty=Client }
        { Category="Behavior" }
        Property Boolean pbGroupsCollapsible True
        
        { WebProperty=Client }
        { Category="Behavior" }
        Property Boolean pbGroupsCollapseByDefault False
        
        { Visibility=Private }
        Property Handle[] phoColumnObjects            // ordered list of cWebColumn objects (in left to right column order)
        { Visibility=Private }
        Property Boolean pbNotifyingExternalDD False  // Private: Used to indicate to the Refresh event that we are handling an event generated by some action on the list/grid control (i.e. delete row, change row, etc)
        { Visibility=Private }
        Property Boolean pbGridBehavior False         // Private: Used by cWebColumn objects to test if they live in a cWebList (read only) or a cWebGrid (save and other stuff is supported)
        { Visibility=Private }
        Property Boolean pbInClearGrid False          // Private: should be set when a DD Clear is supposed refresh an empty grid instead of adding a new row            
        
        { Category="Error Handling" }
        Property Boolean pbSuppressCacheError True // if a record cannot be found in cache, do we report the error?        
        // Published Properties
        { WebProperty=Client } 
        { Category="Behavior" }
        Property Boolean pbColumnSortable True      // If true, column sorting is allowed (which may be server side or client side)
        { WebProperty=Client } 
        { Category="Behavior" }
        Property Boolean pbAutoSearch True          // If true the search dialog will popup automatically when the user starts typing
        { WebProperty=Client } 
        { Category="Appearance" }
        Property Boolean pbShowSelected True        // If true the list will visually show which row is selected.
        { WebProperty=Client } 
        { Category="Appearance" }
        Property Boolean pbShowHeader True          // If true the list will show a header that allows the user to see the column captions and sorting.
        { WebProperty=Client } 
        { Category="Appearance" }
        Property Boolean pbShowFooter False          // If true the list will show a footer that allows the user to see the footer information.
        { WebProperty=Client }
        { Category="Behavior" }
        Property Boolean pbScroll True              // If true the list will scroll vertically
        
        { WebProperty=Client } 
        { Category="Behavior" }
        Property Boolean pbReverseOrdering False    // If true then the current grid ordering is reversed
        { WebProperty=Client } 
        { Visibility=Private }
        Property Boolean pbUnOrdered False          // If True then the grid data has potentially become unordered due to changes in the data
        { WebProperty=Client } 
        { Category="Behavior" }
        Property Integer piSortColumn -1            // Indicates which column the grid is currently sorted on (-1 means the data is sorted via piOrdering)
        { WebProperty=Client } 
        { DesignTime=False }
        Property String psCurrentRowId ""           // Row ID of the currently selected row.
        { WebProperty=Client } 
        { DesignTime=False }
        Property Integer piCurrentRowIndex -1       // The row index of the currently selected row on the client. Does not reflect row changes on the server within the current request. Note that if peGridType is set to gtAutomatic this number is relative to the rows in cache on the client.
        { WebProperty=Client } 
        { DesignTime=False }
        Property Integer piRowCount 0               // The number of rows currently on the client. Note that if peGridType is set to gtAutomatic this number does not represent the entire set.
        
        { WebProperty=Client } 
        { Category="Behavior" }
        Property Boolean pbColumnsResizable True
        
        { WebProperty=Client }
        { Category="Behavior" }
        Property Boolean pbAutoColumnSizing True
        
        { WebProperty=Client } 
        { Category="Behavior" }
        Property Boolean pbOfflineEditing False      // Optimization: Disable server call on row change
        { WebProperty=Client } 
        { Category="Appearance" }
        Property String psPlaceHolder ""            //  Placeholder text shown if the list has no records
        
        { WebProperty=Server }
        { Category="Behavior" }
        Property Integer piLimitRows 0              // Only show the first x rows (0 = show all), requires peDbGridType to be set to gtAllData or pbScroll to false!
        
        { Visibility=Private }
        { WebProperty=Client } 
        Property String psKeyBuddy ""
        
        { Category="Behavior" }
        Property Handle phoKeyBuddy C_WebUnresolvedObject   //  Can be set to another cWebBaseUIObject and the cWebList will respond to key actions on that control 
        
         
        { WebProperty=Client } 
        { Category="Server Events" }
        Property Boolean pbServerOnRowClick False   // Switches the OnRowClick event on and off
        { WebProperty=Client } 
        { Category="Client Events" }
        Property String psClientOnRowClick ""       // Can be set to a client-side JavaScript event handler for the OnRowClick event
        
        { Category="Behavior" }
        Property Boolean pbAllowDeleteRow False   // Allows deleting rows.
        
        { WebProperty=Client }
        { Category="Behavior" }
        Property Boolean pbAllowColumnReordering True // Allows the moving of columns by dragging.
        { WebProperty=Client }
        { Category="Behavior" }
        Property Boolean pbAllowColumnHiding True // Allows the showing and hiding of columns by context menu.
        
        { WebProperty=Client } 
        { Category="Behavior" }
        Property Boolean pbStoreColumnLayout True
        { WebProperty=Client }
        { Category="Client Events" }
        Property String psClientOnColumnLayoutChanged ""
        { WebProperty=Client } 
        { Category="Server Events" }
        Property Boolean pbServerOnColumnLayoutChanged False
        
        { WebProperty=Client } 
        { Category="Behavior" }
        Property Boolean pbStoreGroupConfig True
        { WebProperty=Client }
        { Category="Client Events" }
        Property String psClientOnGroupConfigChanged ""
        { WebProperty=Client } 
        { Category="Server Events" }
        Property Boolean pbServerOnGroupConfigChanged False
        
        { WebProperty=Client } 
        { Category="Server Events" }
        Property Boolean pbServerOnGroupHeaderToggle False
        
        { Category="Behavior" }
        Property Boolean pbUseCustomHeaderMenu False
        { Category="Behavior" }
        Property Boolean pbUseHeaderMenuOnWholeList False // Implicit (True) if pbShowHeader is (False)
        { Visibility=Private }
        Property Handle phPrivateDefaultHeaderMenu 0
                
        Set psJSClass to "df.WebList"
        Set Auto_Fill_State to True                 // Indicates that server DDO should find first record in it's dataset (important to set True for constrained child grids such as Order Details, for unconstrained lists it does not matter what the value is).
        Set pbShowLabel to False                    // Lists won't have a label by default
        Set piColumnSpan to 0                       // Lists will span the whole width by default (0 does this)
        Set piHeight to 200
    End_Procedure
    
    { MethodType=Event }
    {Visibility=Private}
    Procedure privateOnColumnLayoutChanged
        tWebColumnLayout[] aData
        Handle hoJson
        Boolean bServerOnColumnLayoutChanged
        
        WebGet pbServerOnColumnLayoutChanged to bServerOnColumnLayoutChanged
        Get phoActionJsonData to hoJson
        
        If (bServerOnColumnLayoutChanged and hoJson) Begin
            Get JsonToDataType of hoJson to aData
            
            Send OnColumnLayoutChanged aData
        End
    End_Procedure
    
    { MethodType=Event }
    Procedure OnColumnLayoutChanged tWebColumnLayout[] aLayout
    End_Procedure
    
    Procedure ApplyColumnLayout tWebColumnLayout[] aLayout
        String[] aParams
        Send ClientAction "restoreColumnMapper" aParams aLayout
    End_Procedure
    
    Procedure ResetColumnLayout
        Send ClientAction "restoreColumnMapperDefaults"
    End_Procedure
    
    /*
    Applies the supplied configuration for automatic grouping.
    
    @param  aGroups The group configuration to apply.
    @param  bOptOverrideDefault (default: true) If passed as false then this config will only be 
                                applied if no config is loaded from storage.
    @client-action
    */
    Procedure ApplyGroupConfig tWebGroupConfig[] aGroups Boolean bOptOverrideDefault
        String[] aParams
        If (num_arguments > 1) ;
            Move bOptOverrideDefault to aParams[0]
        Else ;
            Move True to aParams[0]
            
        Send ClientAction "applyGroupConfig" aParams aGroups
    End_Procedure
    
    /*
    Clears the configuration for automatic grouping.
    
    @client-action
    */
    Procedure ClearGroupConfig
        Send ClientAction "clearGroupConfig"
    End_Procedure
    
    { MethodType=Event }
    { Visibility=Private }
    Procedure privateOnGroupConfigChanged
        tWebGroupConfig[] aGroups
        Handle hoJson

        Get phoActionJsonData to hoJson
        
        If (hoJson) Begin
            Get JsonToDataType of hoJson to aGroups
            
            Send OnGroupConfigChanged aGroups
        End
    End_Procedure
    
    { MethodType=Event }
    Procedure OnGroupConfigChanged tWebGroupConfig[] aGroups
    End_Procedure
    
    { MethodType=Event }
    { Visibility=Private }
    Procedure privateOnGroupHeaderToggle
        tWebGroupHeader WebGroupHeader
        Handle hoJson

        Get phoActionJsonData to hoJson
        
        If (hoJson) Begin
            Get JsonToDataType of hoJson to WebGroupHeader
            Send OnGroupHeaderToggle WebGroupHeader
        End
    End_Procedure
    
    { MethodType=Event }
    Procedure OnGroupHeaderToggle tWebGroupHeader WebGroupHeader
    End_Procedure
    
    { Visibility=Private }
    Procedure Attach_Deo_To_Server
        // Ignored if pbDataAware is False
        Boolean bDataAware
    
        Get pbDataAware to bDataAware
        If (bDataAware) Begin        
            Forward Send Attach_Deo_To_Server
        End
    End_Procedure
    

    // returns true if this would be a client sorted field. This is used by
    // grid columns to determine a default setting.
    Function ClientSortable Returns Boolean
        Integer eDBGridType
        Boolean bDataAware bScrollable
        Get pbDataAware to bDataAware
        Get peDbGridType to eDBGridType
        Get pbScroll to bScrollable
        // It can be client sortable as long as it is static
        Function_Return (not(bDataAware) or eDBGridType<>gtAutomatic or not(bScrollable))
    End_Function
    
    // find in DD using eFindMode adjusting for reverse ordering. Use the current index 
    { Visibility=Private }
    Function FindInDD Handle hoDD Integer eMode Returns Boolean
        Integer iOrdering
        Boolean bReverseOrdering

        If (pbNotifyingExternalDD(Self)) Begin
            Error DFERR_PROGRAM "Assert: RefreshListFromDD called with pbNotifyingExternalDD set"
        End

        Get IndexOrder to iOrdering
        WebGet pbReverseOrdering to bReverseOrdering
        Get FindMode eMode bReverseOrdering to eMode
        Send Find of hoDD eMode iOrdering    
        Function_Return (Found)
    End_Function
    
    // used by public FindFromTop and FindFromBottom
    { Visibility=Private }
    Procedure FindFromTB Boolean bFirst
        Handle hoDD
        Boolean bDataAware bFound
        Get pbDataAware to bDataAware
        If bDataAware Begin
            Get Server to hoDD
            Get FindInDD hoDD (If(bFirst,FIRST_RECORD, LAST_RECORD)) to bFound
            //  If not found then the DD didn't change so we must clear the grid
            If (not(bFound)) Begin
                Send ClearGrid
            End
        End
    End_Procedure
    
    // Server action
    //
    // Sent when the client navigates the focus from one row to another.
    // sGoToRow - Indicates how to treat the second parameter:
    //            "row"   - indicates that we are going to a specific row as specified in sToRowID
    //            "first" - indicates that we are going to the first row in the data set. Ignore sToRowID.
    //            "last"  - indicates that we are going to the last row in the data set. Ignore sToRowID.
    //            "new"   - indicates that we are creating a new row. Ignore sToRowID.
    // Returns  - True if the navigation is allowed, otherwise returns False.
    { Visibility=Private }
    Function ChangeCurrentRow String sGotoRow String sToRowID Returns Boolean 
        Handle hoDD
        Integer iMainFile
        RowID riRowID
        Boolean bReturn bOldGridAction bDataAware bSuccess
        String sPreviousRowId
        String[] aParams
        
        Get pbDataAware to bDataAware
        WebGet psCurrentRowId to sPreviousRowId
        
        // Give grid a chance to do its row change logic via AllowChangeSelectedRow
        Get AllowChangeSelectedRow sGotoRow sToRowID to bReturn

        // load the new row
        If (bReturn) Begin   
            If (bDataAware) Begin
                // data-aware
                Get Server to hoDD
                
                Get pbNotifyingExternalDD to bOldGridAction
                If (hoDD) Begin
                    Move (Lowercase(sGotoRow)) to sGotoRow
                    
                    Case Begin
                        Case (sGotoRow = "row")
                            Set pbNotifyingExternalDD to True // indicate that we are simply in a client row change event.
                            // Load the ToRowID's record into the DDO structure. This triggers a refresh to all
                            // connected DDO's including cWebColumn objects
                            Get Main_File of hoDD to iMainFile
                            Move (DeserializeRowID(sToRowID)) to riRowID
                            // load the "to" row into the DDO. Should indirectly set psCurrentRowId
                            Get FindByRowIdEx of hoDD iMainFile riRowID to bSuccess
                            // Handle errors
                            If (not(bSuccess)) Begin
                                Set pbNotifyingExternalDD to False
                                Send HandleCacheError
                            End
                            Case Break
        
                        Case (sGotoRow = "first")
                        Case (sGotoRow = "last")
                            // With first and last, we do a dd Find, which should refresh the entire grid
                            Set pbNotifyingExternalDD to False
                            // With first and last, we do a dd Find, which should refresh the entire grid
                            If (sGotoRow = "first") Begin
                                Get FindInDD hoDD FIRST_RECORD to bSuccess
                            End
                            Else Begin
                                Get FindInDD hoDD LAST_RECORD to bSuccess
                            End

                            //  If not found then the DD didn't cause a refresh so we do it manually here
                            If (not(bSuccess)) Begin
                                Send ClearGrid
                            End
                            
                            
                            Case Break
        
                    Case End               
                    Set pbNotifyingExternalDD to bOldGridAction
                                    
                End
                Else Begin
                    Error DFERR_PROGRAM C_$WebGridDoesNotHaveDDOServer
                End
            End
            Else Begin
                // non-data-aware: We simply load the row sent by the client into the DEOs (columns)
                If (sGotoRow = "row") Begin
                    Send FillFromActionData 
                End
            End
            
            //  Fire user event
            Send OnChangeCurrentRow sPreviousRowId sToRowID
        End
        
        //  Send client action that processes the row change (this is done to preserve the order combined with list refreshes)
        Move bReturn to aParams[0]
        Send ClientAction "handleRowChange" aParams
        
        Function_Return bReturn
    End_Function
    
    
    //  Called by the client when the sorting is changed. The piSortColumn and pbReverseSorting are
    //  already updated when it is called.
    { Visibility=Private }
    Procedure ChangeSorting Integer iCol Boolean bReverse Integer iPrevCol Boolean bPrevReverse
        Send GridRefresh
    End_Procedure
    
    
    // Returns the number of columns 
    Function ColumnCount Returns Integer
        Handle[] hoColumnObjects
        Get phoColumnObjects to hoColumnObjects
        Function_Return (SizeOfArray(hoColumnObjects))
    End_Function


