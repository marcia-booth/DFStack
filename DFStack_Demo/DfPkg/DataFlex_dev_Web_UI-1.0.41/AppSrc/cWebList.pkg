    // RegisterColumn:
    
    // Registers a column object in the columns collection.
    { Visibility=Private }
    Procedure RegisterColumn Handle hoColumn
        Integer iSize
        Handle[] hoColumnObjects
        Get phoColumnObjects to hoColumnObjects
        Move (SizeOfArray(hoColumnObjects)) to iSize
        Move hoColumn to hoColumnObjects[iSize]
        Set piColumnId of hoColumn to iSize
        Set phoColumnObjects to hoColumnObjects
    End_Procedure
    
    
    // Sent by DDO when there is a clear/find/save/delete.
    //
    // eMode - Determines the type of DDO operation which generated this refresh message. 
    //         It may be one of the following:
    //         Mode_Clear:             Used only for DEOs attached to the DDO that was the
    //                                 "origin" of a Clear operation, (i.e., the DDO received
    //                                 the original Clear message). All other DDOs Send their 
    //                                 DEOs the refresh message passing mode_find_or_clear_set.  
    //         Mode_Find_or_Clear_Set: Used for DEOs attached to DDOs which have Found and/or cleared records.  
    //         Mode_Clear_All:         Used for DEOs attached to any DDO that participated in a clear_all operation.  
    //         Mode_Delete:            Used for DEOs attached to any DDO that performed a successful deletion. 
    //                                 DDOs that were merely updated as the result of a deletion Use Mode_Find_or_Clear_Set.  
    //         Mode_Save:              Used for DEOs attached to any DDO involved in a successful Save operation. 
    { MethodType=Event }
    Procedure Refresh Integer eMode
        Integer iMainFile
        Integer eDDStatus
        Handle hoDDO
        Boolean bActive bAppSynching bMainFound
        Boolean bRowDisplay bInClearGrid bDataAware 
        Integer eDBGridType
        String sCurrentRowID
        RowID riCurrentRowID riID
        Integer iCurrentRowIndex
        
        Get Active_State to bActive
        Get AppSynching to bAppSynching
        Get pbDataAware to bDataAware
        Get peDbGridType to eDBGridType

        If (bDataAware and bActive and not(bAppSynching)) Begin
            Get Server to hoDDO                  // hoDDO cannot be 0 otherwise we would never receive Refresh!
            Get Main_File of hoDDO to iMainFile
        
            Get DDRefreshTableStatus iMainFile to eDDStatus
            Move (eDDStatus <> ddrtsNone) to bMainFound     // True = a main dd find or constrained child dd find has occurred
            Get pbNotifyingExternalDD to bRowDisplay                 // True = we are simply responding to a change of the current row ID on the client
            
            // Get the current row's row id
            WebGet psCurrentRowId to sCurrentRowID
            Move (DeserializeRowID(sCurrentRowID)) to riCurrentRowID
            WebGet piCurrentRowIndex to iCurrentRowIndex
        
            // Handle the case where there is no selected row and we've done a save or delete on the main file.
            // We don't know what to do in this case so we will refresh the grid. This could happen if the save
            // is occuring from an external source (e.g., create a new record directly in the DD)
            If (iCurrentRowIndex=-1 and (eMode = MODE_SAVE or eMode = MODE_DELETE) and bMainFound and (not(bRowDisplay))) Begin
                Move MODE_FIND_OR_CLEAR_SET to eMode
            End

            // If this is a clear on the grid's main file and it is not grid insert/append row, all we can do is clear and refresh the grid
            Get pbInClearGrid to bInClearGrid
            If (bInClearGrid) Begin
                Move MODE_FIND_OR_CLEAR_SET to eMode
            End

            If (eMode = MODE_CLEAR and bMainFound and sCurrentRowID <> "") Begin
                //  HW: Added check for empty current row id which prevents recursive clearing with two grids on a single DD.
                // special case with clear. If this comes from some other DEO (which is unusual)
                // and the curent row has a record, then we need to insert a row for the
                // cleared row.
                If (not(bRowDisplay)) Begin
                    Send AppendNewRow
                End
                
                Send UpdateCurrentRowID
            End
            
            Else If (eMode = MODE_DELETE or eMode = MODE_SAVE or bRowDisplay or not(bMainFound)) Begin
                // Perform necessary actions for Save or Delete of a Grid Row
                If (hoDDO = OPERATION_ORIGIN) Begin    // OPERATION_ORIGIN is the DDO that is the origin of the Save, Delete, find or clear
                    // if a save notification and the save's DD is the same as the grid's
                    // we are saving the main record and it may now be out of order
                    If (eMode = MODE_SAVE) Begin
                        WebSet pbUnOrdered to True
                    End
                End

                Send UpdateCurrentRowID
            End
            
            Else If (eMode = MODE_CLEAR_ALL) Begin
                Send UpdateCurrentRowID
                If (eDBGridType<>gtManual) Begin
                    Send EmptyGridRefresh
                End
            End
            Else If (eMode = MODE_FIND_OR_CLEAR_SET) Begin
                // If we got here then refresh the entire grid
                Move (GetRowID(iMainFile)) to riID
                Send UpdateCurrentRowID
                If (eDBGridType<>gtManual) Begin
                    Send GridRefresh
                End
                Send ReadByRowId of hoDDO iMainFile riID
            End
        End
    End_Procedure
    
    
    // Does nothing in cWebList. See ClearSelectedRow in cWebGrid class.
    // returns True.
    Function ClearSelectedRow Returns Boolean
        Function_Return True
    End_Function  
    
    // Does nothing in cWebList. cWebList is read only. See SaveSelectedRow in cWebGrid class.
    Function SaveSelectedRow Returns Integer
        Function_Return sroSucceed
    End_Function
    
    // Delete Logic to delete the current row pointed to by psCurrentRowId.
    // returns True if the delete was successful.
    Function DeleteSelectedRow Returns Integer
        Handle hoDD
        Handle hmVerify
        RowID riCurrentRowID riTestRowID
        String sCurrentRowID
        Integer iOrdering iMainFile
        Boolean bReverseOrdering
        Boolean bDataAware
        Integer iReturn

        WebGet psCurrentRowId to sCurrentRowID
        Get pbDataAware to bDataAware
        
        // db-aware handling
        If (bDataAware) Begin
            Get Server to hoDD
            If (hoDD <> 0) Begin
                Move (DeserializeRowID(sCurrentRowID)) to riCurrentRowID
                Get CurrentRowId of hoDD to riTestRowID
                
                If (not(IsSameRowID(riCurrentRowID, riTestRowID))) Begin
                    Error DFERR_PROGRAM "Assert: Server DDO's current record does not match psCurrentRowId"
                    Function_Return sroFail
                End
                
                // Verify that we are allowed to delete
                If (Read_Only_State(hoDD) or not(pbAllowDeleteRow(Self)) or not(Can_Delete(hoDD))) Begin
                    Function_Return sroFail         // the view should not allow this to happen
                End
            End
        End
        
        Get Verify_Delete_msg to hmVerify
        If (hmVerify) Begin
            WebSet pbDeleteCallbackActive to True
            Send VerifyRequest (RefProc(RequestDeleteCallBack)) (RefFunc(Verify_Delete_Msg))
            Function_Return sroPending
        End
        Else Begin
            Send RequestDeleteExec
            // we actually don't know if this will work or not, since this finds another row. For now, we say success
        End
        Function_Return sroSucceed
    End_Function
    
    // This event is triggered by Request_Delete. It is intended to be implemented on grids having 
    // pbDataAware set to false to process the delete. If the delete cannot be performed return 
    // false to cancel the grid from removing the row from the display. Returning false when 
    // pbDataAware is set to true will also cancel the delete from being sent to the DDO.
    { MethodType=Event }
    Function OnDeleteRow String sCurrentRowID Returns Boolean
        Function_Return True
    End_Function        

    
    Procedure RequestDeleteExec
        Handle hoDD
        String sCurrentRowID
        Integer iOrdering iMainFile
        Boolean bReverseOrdering
        Boolean bDataAware bContinue

        WebGet psCurrentRowId to sCurrentRowID
        Get OnDeleteRow sCurrentRowID to bContinue
        
        // db-aware
        Get pbDataAware to bDataAware
        
        If (bDataAware) Begin
            If (bContinue) Begin
                // Perform the db-aware delete
                Get Server to hoDD
                Send Request_Delete to hoDD       // Perform the delete
                            
                If (Err) Begin
                    Procedure_Return
                End
                
                Send RemoveRow sCurrentRowID      // Tell the client to remove the deleted row.
                
                // Select the next logical row
                Get IndexOrder to iOrdering
                WebGet pbReverseOrdering to bReverseOrdering
                Get Main_File of hoDD to iMainFile
        
                If (bReverseOrdering) Begin
                    Send Establish_Find_Direction of hoDD LT iMainFile iOrdering 
                End
                Else Begin
                    Send Establish_Find_Direction of hoDD GT iMainFile iOrdering 
                End
                
                Send Locate_Next of hoDD    // Try to find the row below the deleted row.
                
                If (not(Found)) Begin
                    // If the row below the deleted row was not found then it means we deleted the
                    // last row. Now we will try to load the new last row. If there are no remaining
                    // rows in the dataset then the buffer will be automatically cleared (which is 
                    // what we want)
                    If (bReverseOrdering) Begin
                        Send Request_Read of hoDD FIRST_RECORD iMainFile iOrdering
                    End
                    Else Begin
                        Send Request_Read of hoDD LAST_RECORD iMainFile iOrdering
                    End
                End
                
                If (Found) Begin
                    Send Request_Assign of hoDD iMainFile
                End
                Else Begin
                    Send ClearGrid
                End
                
                Send UpdateCurrentRowID
            End
        End 
        Else Begin
            //  Non DB-Aware handling
             If (bContinue) Begin
                Send RemoveRow sCurrentRowID      // Tell the client to remove the deleted row.
            End
        End
    End_Procedure
    
    // Client action to remove the passed row from the cache. 
    { Visibility=Public }
    Procedure RemoveRow String sRowID
        String[] aParams
        
        Move sRowID to aParams[0]
        Send ClientAction "removeRow" aParams    
    End_Procedure

    // Returns true if you can move off of the selected row.
    // Does nothing in cWebList. cWebList is read only. See AllowChangeSelectedRow in cWebGrid class.
    Function AllowChangeSelectedRow String sGotoRow String sToRowID Returns Boolean
        Function_Return True
    End_Function

    // these don't do anything with lists
    Procedure AppendNewRow    
    End_Procedure

    // these don't do anything with lists
    Procedure InsertNewRow    
    End_Procedure
    
    Function IndexOrder Returns Integer
        // returns the sort order for subsequent DDO Request_Read calls.
        Integer iOrdering iColumnOrdering eDbGridType iConstrainFile
        String iSortColumn
        Handle hoColumn hoDD
        
        
        
        // if DD has an ordering we must use this
        Get Server to hoDD
        If (hoDD > 0) Begin
            Get Ordering of hoDD to iOrdering    // get the sort index from the DDO (if this has been set)
            If (iOrdering<>-1) Begin
                Function_Return iOrdering
            End
        End
            
        Get piOrdering to iOrdering
        If (hoDD > 0) Begin
            // this is the ordering as defined by the grid
            Get Constrain_File of hoDD to iConstrainFile
            // if ordering is not specified and we have a constraining parent
            // we want to limit the constraint to the best choice for a constrained find
            If (iOrdering=-1 and iConstrainFile) Begin
                Get ConstrainedIndexOrder iConstrainFile to iOrdering
            End
        End
        // if a static grid, use the grid's ordering, if dynamic we use
        // the column ordering if we are sorting by a grid column, else use grid ordering
        Get peDbGridType to eDbGridType
        If (eDbGridType=gtAutomatic) Begin
            // If we are sorting by a grid column then use that
            WebGet piSortColumn to iSortColumn
            
            If (iSortColumn <> -1) Begin
                Get GetColumnObject iSortColumn to hoColumn
                If (hoColumn) Begin
                    Get ColumnIndexOrder of hoColumn to iColumnOrdering      // returns -1 if there is no default index
                    If (iColumnOrdering<>-1) Begin
                        Move iColumnOrdering to iOrdering
                    End
                End
            End
        End
        Function_Return iOrdering
    End_Function
    
    
    // return best index for constrained find. Return -1 which asks the runtime
    // to make this choice as normally there is only one choice. 
    // This is suitable for augmentation.
    { Visibility=Private }
    Function ConstrainedIndexOrder Integer iConstrainFile Returns Integer
        Function_Return -1 // the runtime knows best
    End_Function
    
    
    { Visibility=Private }
    Procedure UpdateCurrentRowID
        // Sets the web property psCurrentRowId for pbDataAware=True grid.
        Handle hoDD
        RowID riRowID
        
        // assert pbDataAware=True
        If (not(pbDataAware(Self))) Begin
            Error DFERR_PROGRAM "Assert: UpdateCurrentRowID called for non-data aware grid"
        End
        
        Get Server to hoDD
        
        If (hoDD = 0) Begin
            // This will probably never happen
            Move (NullRowID()) to riRowID
        End
        Else Begin
            Get CurrentRowId of hoDD to riRowID
        End
        
        WebSet psCurrentRowId to (SerializeRowID(riRowID))
    End_Procedure


    // in sub-classes that support auto-server, which uses the
    // invoking server, the server used for reading the grid may
    // be different than the server defined in this view.
    Function ReadingServer Returns Handle
        Handle hoDD
        Get Server to hoDD
        Function_Return hoDD
    End_Function

    // This handles translation of find modes to make reverse ordering
    // work. Pass the mode and return the mode, translated if reverse ordering is needed
    { Visibility=Private }
    Function FindMode Integer eFindMode Boolean bReverseOrdering Returns Integer
        If (bReverseOrdering) Begin
            Case Begin
                Case (eFindMode=GE) ;
                    Move (LE) to eFindMode
                Case (eFindMode=GT) ;
                    Move (LT) to eFindMode
                Case (eFindMode=LT) ;
                    Move (GT) to eFindMode
                Case (eFindMode=LE) ;
                    Move (GE) to eFindMode
                Case (eFindMode=FIRST_RECORD) ;
                    Move (LAST_RECORD) to eFindMode
                Case (eFindMode=LAST_RECORD) ;
                    Move (FIRST_RECORD) to eFindMode
            Case End
        End
        Function_Return eFindMode
    End_Function

    { Visibility=Private }
    Procedure EstablishDDFindMode Integer eFindMode Handle hoServer Integer iOrdering Boolean bReverseOrdering
        Integer iFile
        Get FindMode eFindMode bReverseOrdering to eFindMode  // mode might change if reverse ordering
        Get Main_File of hoServer to iFile
        Send Establish_Find_Direction of hoServer eFindMode iFile iOrdering
    End_Procedure

    { Visibility=Private }
    Function ReadDDFirstRecord Handle hoDD Integer iOrdering Boolean bReverseOrdering  Returns RowID
        Integer iFile eFindMode
        // because this uses request_read it cannot be used inside of refresh
        If (OPERATION_MODE<>0) Begin
            Error DFERR_PROGRAM ("assertion failed: ReadDDFirstRecord is called when DD is busy")
        End
        Get Main_File of hoDD to iFile
        Get FindMode FIRST_RECORD bReverseOrdering to eFindMode
        Send Request_Read of hoDD eFindMode iFile  iOrdering
        Function_Return (GetRowID(iFile))
    End_Function
    
    
    { Visibility=Private }
    Function ReadDDLastRecord Handle hoDD Integer iOrdering Boolean bReverseOrdering  Returns RowID
        Integer iFile eFindMode
        // because this uses request_read it cannot be used inside of refresh
        If (OPERATION_MODE<>0) Begin
            Error DFERR_PROGRAM ("assertion failed: ReadDDFirstRecord is called when DD is busy")
        End
        Get Main_File of hoDD to iFile
        Get FindMode LAST_RECORD bReverseOrdering to eFindMode
        Send Request_Read of hoDD eFindMode iFile iOrdering
        Function_Return (GetRowID(iFile))
    End_Function
    
    { Visibility=Private }
    Function ReadDDRecordInBuffer Handle hoDD Integer iOrdering Boolean bReverseOrdering Returns Boolean
        Boolean bFound
        RowID riId
        Integer iFile
        
        Send EstablishDDFindMode Ge  hoDD iOrdering bReverseOrdering
        Send Locate_Next of hoDD
        Move (Found) to bFound
        If not bFound Begin
            Get ReadDDLastRecord hoDD iOrdering bReverseOrdering to riId
        End
        Else Begin
            Get Main_File of hoDD to iFile
            Move (GetRowID(iFile)) to riId
        End
        Function_Return (not(IsNullRowID(riId)))
    End_Function

    // finds the record in the buffer and rebuilds the list. If the
    // buffer record is not found, most likely due to a failed constraint), it
    // search for the next record (where next is determined by reverse ordering).
    // If there is no record, it will attemot to find the prior record. 
    Procedure FindDDRecordInBuffer 
        Boolean bReverseOrdering bFound
        Integer iOrdering
        Handle hoDD

        Get ReadingServer to hoDD
        Get IndexOrder to iOrdering
        WebGet pbReverseOrdering to bReverseOrdering
        
        Get ReadDDRecordInBuffer hoDD iOrdering bReverseOrdering to bFound
        
        Get Server to hoDD
        If bFound Begin
            Send Request_Assign of hoDD
        End
        Else Begin
            Send ClearGrid
        End
    End_Procedure
    
    
    // Clears the DD and creates an empty grid.
    // The Clear DD behavior can work different ways with grids. Most of the time, a clear to a DD should
    // just open up a new row for editing. This is consistent with what clear does everyhwere else. However, there are
    // times when you need to create an empty grid. This will mostly happen when there are no valid records to display so you
    // need to create an empty grid. That's what this message is for.
    // For now this is public, but it needs to be used carefully. If you are clearing grids when there are records that could be
    // displayed, you are fighting a normal grid behavior.
    Procedure ClearGrid
        Boolean bInClearGrid bDataAware
        Handle hoDD
        
        Get pbDataAware to bDataAware
        
        If (bDataAware) Begin
            Get pbInClearGrid to bInClearGrid
            Set pbInClearGrid to True
            Get Server to hoDD
            Send Clear of hoDD
            Set pbInClearGrid to bInClearGrid
        End
        Else Begin
            Send EmptyGridRefresh
        End
    End_Procedure
    
    
    // Appends a row to the end of the list. It will update the user interface if needed. Should
    // only be used on a manually loaded list (pbDataAware = false or peDbGridType = gtManual). 
    // Implemented as a client-action meaning that it works asynchronously.
    //
    // Params:
    //  tRow    Filled tWebRow struct with the new row data.
    Procedure DataSetAppendRow tWebRow tRow
        String[] aParams
        tWebRow[] aRows
        Handle hoJson
        
        Move tRow to aRows[0]
        
        //  Convert data to JSON
        Get Create (RefClass(cJsonObject)) to hoJson
        Send DataTypeToJson of hoJson aRows
        
        Send ClientActionEx "dataSetAppendRow" aParams hoJson
        Send Destroy of hoJson
    End_Procedure
    
    // Inserts a new row into the list before the row with the provided rowid. If the rowid is not
    // found it will append the row to the end of list. Should only be used on a manually loaded
    // list (pbDataAware = false or peDbGridType = gtManual). Implemented as a client-action 
    // meaning that it works asynchronously.
    //
    // Params:
    //  sRowIdBefore    RowID of the row before which the new row should be inserted.
    //  tRow            Filled tWebRow struct with the new row data.
    Procedure DataSetInsertRowBefore String sRowIdBefore tWebRow tRow
        String[] aParams
        tWebRow[] aRows
        Handle hoJson
        
        Move tRow to aRows[0]
        
        //  Convert data to JSON
        Get Create (RefClass(cJsonObject)) to hoJson
        Send DataTypeToJson of hoJson aRows

        Move sRowIdBefore to aParams[0]
        
        Send ClientActionEx "dataSetInsertRowBefore" aParams hoJson
        Send Destroy of hoJson
    End_Procedure
    
    // Inserts a new row into the list after the row with the provided rowid. If the rowid is not
    // found it will append the row to the end of list. Should only be used on a manually loaded
    // list (pbDataAware = false or peDbGridType = gtManual). Implemented as a client-action 
    // meaning that it works asynchronously.
    //
    // Params:
    //  sRowIdBefore    RowID of the row before which the new row should be inserted.
    //  tRow            Filled tWebRow struct with the new row data.
    Procedure DataSetInsertRowAfter String sRowIdAfter tWebRow tRow
        String[] aParams
        tWebRow[] aRows
        Handle hoJson
        
        Move tRow to aRows[0]
        
        //  Convert data to JSON
        Get Create (RefClass(cJsonObject)) to hoJson
        Send DataTypeToJson of hoJson aRows

        Move sRowIdAfter to aParams[0]
        
        Send ClientActionEx "dataSetInsertRowAfter" aParams hoJson
        Send Destroy of hoJson
    End_Procedure
    
    
    
    // Updates a row within the list with the provided data. Should only be used on a manually 
    // loaded list (pbDataAware = false or peDbGridType = gtManual). Implemented as a client-action
    // meaning that it works asynchronously.
    //
    // Params:
    //  sRowID      RowID of the row that needs to be updated.
    //  tRow        Filled tWebRow struct with the new data.
    Procedure DataSetUpdateRow String sRowID tWebRow tRow
        String[] aParams
        tWebRow[] aRows
        Handle hoJson
        
        Move tRow to aRows[0]
        
        //  Convert data to JSON
        Get Create (RefClass(cJsonObject)) to hoJson
        Send DataTypeToJson of hoJson aRows
        
        Move sRowID to aParams[0]
        
        Send ClientActionEx "dataSetUpdateRow" aParams hoJson
        
        Send Destroy of hoJson
    End_Procedure
    
    
    // Removes a row from the list. Should only be used on a manually loaded list (pbDataAware = 
    // false or peDbGridType = gtManual). Implemented as a client-action meaning that it works 
    // asynchronously.
    //
    // Params:
    //  sRowId      RowID of the row that needs to be removed.
    Procedure DataSetRemoveRow String sRowId
        String[] aParams
        
        Move sRowID to aParams[0]
        
        Send ClientAction "dataSetRemoveRow" aParams
    End_Procedure
    
    // Makes the first row the selected row. If the list is data bound and peDbGridMode is 
    // automatic this means that the grid data will be refreshed from the server. Note that 
    // OnChangeCurrentRow will be fired as usual.
    Procedure MoveToFirstRow
        Send ClientAction "moveToFirstRow"
    End_Procedure
    
    // Makes the last row the selected row. If the list is data bound and peDbGridMode is automatic
    // this means that the grid data will be refreshed from the server. Note that
    // OnChangeCurrentRow will be fired as usual.
    Procedure MoveToLastRow
        Send ClientAction "moveToLastRow"
    End_Procedure
    
    // Selects the row one page up. The size of a page depends on the height of the list.Procedure MovePageUp
    Procedure MovePageUp
        Send ClientAction "movePageUp"
    End_Procedure
    
    // Selects the row one page down. The size of a page depends on the height of the list.
    Procedure MovePageDown
        Send ClientAction "movePageDown"
    End_Procedure
    
    // Selects the previous row.
    Procedure MoveUpRow
        Send ClientAction "moveUpRow"
    End_Procedure
    
    // Selects the next row.
    Procedure MoveDownRow
        Send ClientAction "moveDownRow"
    End_Procedure
    
    // Selects a specific row by its row index.
    Procedure MoveToRow Integer iRowIndex
        String[] aParams
        
        Move iRowIndex to aParams[0]
        
        Send ClientAction "moveToRow" aParams
    End_Procedure
    
    // Selects a specific row by its rowid.
    Procedure MoveToRowByID String sRowID
        String[] aParams
        
        Move sRowID to aParams[0]
        
        Send ClientAction "moveToRowByID" aParams
    End_Procedure
    
    // Collapses all displayed groups (only if pbGroupsCollapsible is true)
    Procedure CollapseAllGroups
        Send ClientAction "collapseAllGroups"
    End_Procedure
    
    // Expands all displayed groups
    Procedure ExpandAllGroups
        Send ClientAction "expandAllGroups"
    End_Procedure
    
    // Scrolls a column into the view by scrolling horizontally. Can only be used when 
    // pbAutoColumnSizing is false and pbScroll is true.
    Procedure ScrollToColumnObject Handle hoColumn
        Handle[] aColumnObjects
        Integer iColumnIndex
        String[] aParams
        
        Get phoColumnObjects to aColumnObjects
        
        Move (SearchArray(hoColumn, aColumnObjects)) to iColumnIndex
        
        If (iColumnIndex >= 0) Begin
            Move iColumnIndex to aParams[0]    
        
            Send ClientAction "scrollToCol" aParams
        End
        Else Begin
            Error DFERR_PROGRAM "Invalid column handle!"
        End
    End_Procedure
    
    
    // Client action that triggers the grid to send the entire set of data in a separate request. 
    // This request is handled by HandleProcessDataSet and triggers the OnProcessDataSet event that 
    // should be implemented to save / process the data of the grid.
    Procedure ProcessDataSet Integer eOperation
        String[] aParams
        
        Move eOperation to aParams[0]
        
        Send ClientAction "processDataSet" aParams
    End_Procedure
    
    // Published method that is called by the client to save the entire set of data. It gets the 
    // action data and triggers the OnProcessDataSet event.
    { Visibility=Private }
    Procedure HandleProcessDataSet Integer eOperation Integer iSelectedRowIndex
        tWebRow[] aData
        Handle hoJson
        
        Get phoActionJsonData to hoJson
        Get JsonToDataType of hoJson to aData
        
        Send OnProcessDataSet aData eOperation iSelectedRowIndex
    End_Procedure
    
    // Event that is called by the client grid class to pass the entire set of data that the grid 
    // was working on. Implement this event to store all the grid data at once. Use the ProcessDataSet
    // method to trigger this event.
    { MethodType=Event }
    Procedure OnProcessDataSet tWebRow[] aData Integer eOperation Integer iSelectedRowIndex
    End_Procedure
    
    //  Called when a row is loaded to define the CSS class for that row. The global buffers will
    //  have the proper record loaded for a data aware grid.
    { MethodType=Event }
    Procedure OnDefineRowCssClass String ByRef sCSSClass
    End_Procedure
    
    // Shows the search dialog.
    Procedure Search
        Send ClientAction "showSearch"
    End_Procedure
    
    
    // Called by the JavaScript engine to perform a search on an automatic data aware list
    // (peDbGridType = gtAutomatic and pbDataAware = true). It can just perform the find on the DD
    // and the list will refresh itself and select the right record.
    { MethodType=Event } 
    Procedure OnSearch String sSearchText
        Integer iCol
        Handle hoCol
        WebGet piSortColumn to iCol

        If (iCol>=0) Begin
            Get GetColumnObject iCol to hoCol
            
            // Perform the lookup
            Send RequestColumnLookup of hoCol sSearchText
        End
    End_Procedure

    // Attempt to find the field from the server's MainFile that relates to iRelatedFile
    { Visibility=Private }
    Function RelatingField Integer iRelatedFile Returns Integer
        Integer iField iRelFile iNumFields iIndex iMainfile
        Handle hoServer
        Boolean bDDRelates
        Get Server to hoServer
        Get Main_File of hoServer to iMainfile
        Get pbUseDDRelates of hoServer to bDDRelates
        Get_Attribute DF_FILE_NUMBER_FIELDS of iMainFile to iNumFields
        For iField from 1 to iNumFields
            
            // find first field that relates to the related file and has an index.
            If (bDDRelates) Begin
                Get Field_Related_File of hoServer iField to iRelFile
            End
            Else Begin
                Get_Attribute DF_FIELD_RELATED_FILE of iMainFile  iField to iRelFile
            End
            
            If (iRelFile=iRelatedFile) Begin
                
                If (bDDRelates) Begin
                    Get Field_Related_Field of hoServer iField to iIndex
                End
                Else Begin
                    Get_Attribute DF_FIELD_INDEX of iMainFile iField to iIndex
                End
                
                If (iIndex>0) Begin
                    Function_Return iField
                End
            End
        Loop
        Function_Return -1
    End_Function

    // refresh DD aware Grid from the Top
    Procedure FindFromTop
       Send FindFromTB True
    End_Procedure

    // refresh DD aware Grid from the Bottom
    Procedure FindFromBottom
       Send FindFromTB False
    End_Procedure
    
    // called for Select views to refresh the select list during back navigation.
    // If a cancel, there is no target DD and no rowId. Just refresh around what's in the DDO
    // If a close, we have a RowId for a target DDO. If the DDO matches this list's DDO, refresh 
    // around that. 
    // For now this is private
    { Visibility=Private }
    Procedure RefreshListForBackNavigation Boolean bCancel Handle hoDDTarget RowID riTarget
        Boolean bDataAware bSuccess
        Handle hoDD
        Integer iMain
        RowID riId
        
        If (pbGhost(Self)) ;
            Procedure_Return
        
        Get pbDataAware to bDataAware
        // if non-data aware there is no list update
        If bDataAware Begin
            // if close & update, with a different rowid refind the rowid passed in. 
            If not bCancel Begin
                Get Server to hoDD
                If (hoDD and hoDD=hoDDTarget) Begin // test to make sure this is an appropriate list to update
                    Get Main_File of hoDD to iMain
                    Get CurrentRowId of hoDD to riId
                    If (not(IsNullRowID(riTarget)) and not(IsSameRowID(riId,riTarget))) Begin
                        // this will cause the list to refresh itself
                        Get FindByRowIdEx of hoDD iMain riTarget to bSuccess
                        If not bSuccess Begin
                            Send HandleCacheError
                        End
                        Procedure_Return
                    End
                End
            End
            // else, refresh with current information around existing DD
            Send RefreshListFromDD
        End
    End_Procedure

    
    
    // Refresh a data-aware grid around the current record in the DD
    // If that record is 0 or not found, which you really don't want to happen,
    // just refresh from firsts record
    Procedure RefreshListFromDD
        Handle hoDD
        RowID riId
        Integer iMain
        Boolean bDataAware bSuccess
        Get pbDataAware to bDataAware
        If bDataAware Begin

            If (pbNotifyingExternalDD(Self)) Begin
                Error DFERR_PROGRAM "Assert: RefreshListFromDD called with pbNotifyingExternalDD set"
            End

            Get Server to hoDD
            Get Main_File of hoDD to iMain
            Get CurrentRowId of hoDD to riId
            Move False to bSuccess
            

            
            If (not(IsNullRowID(riId))) Begin
                // test to see if the record still exists
                Get FindByRowIdEx of hoDD iMain riId to bSuccess 
            End
            
            If (not(bSuccess)) Begin
                // missing record, we don't know what to do.
                // Just refresh the entire list
                Get FindInDD hoDD FIRST_RECORD to bSuccess
                If (not(bSuccess)) Begin
                    Send ClearGrid
                End
            End
        End
    End_Procedure
    
    
    // This event procedure is called when a row is clicked within the list and pbServerOnRowClick 
    // is true. It is called after the actual row change is performed which means that if the row 
    // change succeeded the psCurrentRowId matches the clicked row id. In case of a cWebGrid row 
    // changes can fail due to validation issues so in that case the clicked row can be different. 
    // Note that if pbOfflineEditing is true the buffer will not contain the selected row.
    //
    // Params:
    //  sRowID          The rowid of the clicked row.
    //  iColumnIndex    The cWebColumn object index (excl. non-cWebColumn siblings).
    //                  When pressing enter in a cWebList this will be -1.
    { MethodType=Event }
    Procedure OnRowClick String sRowID Integer iColumnIndex
        //  Empty event stub
    End_Procedure

    // Callback method sent to the callback control when a view receives NavigateForward.
    // This should populate the tWebNavigateData in the default way according to the control's data bindings.
    { Visibility=Private }
    Procedure GetNavigateBackData Handle hoView tWebNavigateData ByRef NavigateData
        Integer eGridType
        String sId
        Handle hoServer 
        RowID ri
        Boolean bOk bDataAware
        
        // Populate the Navigate Data struct with the best guess values from
        // this control's server DDO
        Get Server to hoServer
        If (hoServer) Begin
            WebGet peDbGridType to eGridType
            WebGet pbDataAware to bDataAware
            If (bDataAware and  eGridType<>gtAutomatic) Begin
                WebGet psCurrentRowId     to sId
                Get FindByRowIdEx of hoServer (Main_File(hoServer)) (DeserializeRowID(sId)) to bOk
            End
            
            WebGet psCurrentRowId     to sId
            Get CurrentRowId of hoServer to ri
            If (not(IsSameRowID(ri,(DeserializeRowID(sId))))) Begin
                Error DFERR_PROGRAM "Assert: Different ids in weblist"
            End

        End
        Forward Send GetNavigateBackData hoView (&NavigateData)
        
    End_Procedure
    
    
    // Callback method sent to the callback control when a view receives NavigateForward.
    // This should populate the tWebNavigateData in the default way according to the control's data bindings.
    { Visibility=Private }
    Procedure GetNavigateForwardData Handle hoView tWebNavigateData ByRef NavigateData
        Integer eGridType
        String sId
        Handle hoServer 
        RowID ri
        Boolean bOk bOldGridAction bFromDynamic
        
        // Populate the Navigate Data struct with the best guess values from
        // this control's server DDO
        Get Server to hoServer
        // if not dataaware there will be no server!
        If (hoServer) Begin
            WebGet peDbGridType to eGridType
            WebGet psCurrentRowId     to sId
            // if not automatic, the server's row Id may not be current yet. 
            If (eGridType<>gtAutomatic) Begin
                Get pbNotifyingExternalDD to bOldGridAction
                Set pbNotifyingExternalDD to True
                Get FindByRowIdEx of hoServer (Main_File(hoServer)) (DeserializeRowID(sId)) to bOk
                Set pbNotifyingExternalDD to bOldGridAction
            End
            
            // If the navigation is executed by a dynamic object, we don't care about this sanity check - especially durin initialization
            Get IsDynamicObject to bFromDynamic
            If (not(bFromDynamic) and not(pbGhost(Self))) Begin
                // Assert that the Server's rowid matches the weblist's current row id
                // if the DDO has no record, it is possible it could not refind what it
                // needed and cleared it. We will not consider this an error, although it
                // may display odd stuff (like a cleared parent).
                Get CurrentRowId of hoServer to ri
                If (not(IsNullRowID(ri)) and  not(IsSameRowID(ri,(DeserializeRowID(sId))))) Begin
                    Error DFERR_PROGRAM "Assert: Different ids in weblist"
                End
            End

        End
        Forward Send GetNavigateForwardData hoView (&NavigateData)
    
    End_Procedure
    
    // Special augmentation for weblists. If this is not a dataaware grid, we want the server
    // to be 0. We also want any child DEOs to have a 0 server, which they will
    { NoDoc=True }
    Function Server Returns Integer
        Boolean bDataAware
        Handle hoServer
        
        // note we use the property and not the web-property. Even though this is a web-property
        // it is not expected that this would ever be webset changed
        Get pbDataAware to bDataAware
        If (bDataAware) Begin
            Forward Get Server to hoServer
        End
        Function_Return hoServer
    End_Function

    // This message is broadcast to all controls in a list view when
    // navigating to the view. It is intended to allow the controls to set the
    // ordering of row data (e.g. piOrdering)
    {Visibility=Private}
    Procedure InitOrdering tWebNavigateData NavigateData Handle hoInvokingObject
        Integer iMainTable iSortCol
        Integer eDbGridType
        Handle hoServer hoMainDD
        Boolean bDataAware bReverseOrdering
    
        Get Server to hoServer
        Get Main_DD to hoMainDD
        
        // If no server or the server is not the view's main server, do nothing
        If (hoServer=0 or hoServer<>hoMainDD) Begin
            Procedure_Return
        End
        
        Get pbDataAware to bDataAware
        Get peDbGridType to eDbGridType
        
        // restore to design time values
        Get pbReverseOrdering to bReverseOrdering
        WebSet pbReverseOrdering to bReverseOrdering

        Get piSortColumn to iSortCol
        WebSet piSortColumn to iSortCol

        // if data-aware and autoloading we assign an automatic sort column    
        If (eDbGridType <> gtManual and bDataAware) Begin
            If (NavigateData.eNavigateType <> nfFromParent) Begin
                Get Main_File of hoServer to iMainTable
                If (iMainTable = NavigateData.iTable and iMainTable <> 0) Begin
                    Get SelectBestColumn NavigateData.iTable NavigateData.iColumn to iSortCol
                    If (iSortCol>=0) Begin
                        WebSet piSortColumn to iSortCol
                    End
                End
            End
        End
    End_Procedure 
    
    // This message is broadcast to a Select view when navigating to the view and there is no 
    // record for the grid. It is intended to allow the list control to fill itself
    // automatically when appropriate. It only does a fill if this is data aware grid,
    // and the grid's server is the view's main DD. It simply loads from the "first" record 
    {Visibility=Private}
    Procedure InitGrid tWebNavigateData NavigateData Handle hoInvokingObject
        Integer iIndex iMainTable
        Integer eDbGridType
        Handle hoServer hoMainDD
        Boolean bSeeded bReverseOrdering bDataAware
        Boolean bOldGridAction
    
        Get Server to hoServer
        Get Main_DD to hoMainDD
        If (hoServer=0 or hoServer<>hoMainDD) Begin
            Procedure_Return
        End
        
        Get pbDataAware to bDataAware
        Get peDbGridType to eDbGridType
        
        // if manually loaded or not data aware we will not do any init here. It can be done
        // in OnNavigateForward
        If (eDbGridType = gtManual or not(bDataAware)) Begin
            Procedure_Return
        End
        
        Get pbReverseOrdering to bReverseOrdering
        Get Main_File of hoServer to iMainTable
        Get IndexOrder to iIndex

        // Init list at the "start"
        If (bReverseOrdering) Begin
            Send Find of hoServer LAST_RECORD iIndex
        End
        Else Begin
            Send Find of hoServer FIRST_RECORD iIndex
        End

        // If the seeding succeeded then ensure that all controls latch onto this
        // otherwise just clear the DDOs
        Get HasRecord of hoServer to bSeeded
        
        If bSeeded Begin
            // this only updates the current record and does not refill the grid
            Get pbNotifyingExternalDD to bOldGridAction
            Set pbNotifyingExternalDD to True
            Send Request_Assign of hoServer
            Set pbNotifyingExternalDD to bOldGridAction
        End
        Else Begin
            Send ClearGrid
        End
    End_Procedure 

    Function SelectBestColumn Integer iFile Integer iField Returns Integer
        Integer iCol iColFile iColField
        Boolean bCol
        Handle[] hoColumnObjects
        
        Get phoColumnObjects to hoColumnObjects
        For iCol from 0 to (SizeOfArray(hoColumnObjects)-1)
            Get pbIsWebColumn of hoColumnObjects[iCol] to bCol
            If (bCol) Begin
                Get Data_File of hoColumnObjects[iCol] iCol to iColFile
                If iFile Begin
                    Get Data_Field of hoColumnObjects[iCol] iCol to iColField
                    If (iColFile=iFile and iColField=iField) Begin
                        Function_Return iCol
                    End
                End
            End
        Loop
        Function_Return -1
    End_Function
    
    Function DragData Returns Variant
        tWebListDragData DragData
        Handle hoJsonData 
        
        Get phoJsonDragData to hoJsonData
        If (hoJsonData <> C_WebUnresolvedObject) Begin
            Get JsonToDataType of hoJsonData to DragData
        End
        
        Function_Return DragData
    End_Function
    
    Function DropData Returns Variant
        tWebListDropData DropData
        Handle hoJsonData
        
        Get phoJsonDropData to hoJsonData
        
        If (hoJsonData <> C_WebUnresolvedObject and IsOfJsonType(hoJsonData, jsonTypeObject)) Begin
            Set pbRequireAllMembers of hoJsonData to False
            Get JsonToDataType of hoJsonData to DropData
        End
        
        Function_Return DropData
    End_Function
    
    {Visibility = Private}
    Function SupportsDragAction Integer eAction Returns Boolean
        If (eAction = C_WebDragListRow) Begin
            Function_Return True
        End
        
        Function_Return False
    End_Function
    
    {Visibility = Private}
    Function SupportsDropAction Integer eAction Returns Boolean
        Boolean bSupported
        
        Forward Get SupportsDropAction eAction to bSupported
        
        If (not(bSupported)) Begin
            If (eAction = C_WebDropListRow) Begin
                Move True to bSupported
            End
        End
        
        Function_Return bSupported
    End_Function

    // this exposed so developers can create their own error text
    Procedure ReportCacheError
        Error DFERR_CANT_REFIND_RECORD C_$InvalidRowInCache
    End_Procedure

    // called when a record in the cache cannot be refound. Most likely this was deleted
    // by another user.
    // optionally report the error and do a refresh based around the current DD
    Procedure HandleCacheError
        Boolean bSuppressCacheError
        
        Get pbSuppressCacheError to bSuppressCacheError
        If not bSuppressCacheError Begin 
            Send ReportCacheError
        End
        // reload the list based on current DD (this may also fail)
        Send RefreshListFromDD        
    End_Procedure
    
    
    // This method is received by the Web Control that is the target of a CallAction that is sent
    // from the client. Augmented to perform format conversion for parameters passed to OnSearch.
    // methods.
    { Visibility=Private }
    Function HandleAction String sAction String[] aParams Handle hoAttachment Returns String
        Integer i icParameters iCol
        Integer eDataType
        Handle hoCol
        String sReturnVal
        
        // Get the parameter count
        Move (SizeOfArray(aParams)) to icParameters
        
        // Special Case: OnChange
        If (Uppercase(sAction) = "ONSEARCH") Begin
            // If the action is an OnSearch event then we must test if the data type is a number, 
            // Date or DateTime. If so we must convert each parameter value from the universal 
            // transfer format
            WebGet piSortColumn to iCol
    
            If (iCol >= 0) Begin
                // Query the data type of the current sort column
                Get GetColumnObject iCol to hoCol
                Get peDataType of hoCol to eDataType
                // Note: For efficienty we do not WebGet peDataType! In other words we do not
                // get the "synchronized copy of peDataType (if there is one). This is much more
                // efficient but it also assumes that a control's peDataType does not change 
                // dynamically. This should be OK
                
                // Send Hook for converting the value to format for transport.
                For i from 0 to (icParameters - 1)
                    Move (ConvertFromClient(eDataType, aParams[i])) to aParams[i]
                Loop
            End
        End
        
        // Now call the superclass's implementation of HandleAction 
        Forward Get HandleAction sAction aParams hoAttachment to sReturnVal
        
        Function_Return sReturnVal
    End_Function
    
    // Augment to make sure LoadDataPage is allowed when the control is disabled as well.
    { Visibility=Private }
    Procedure AllowServerAction Boolean  ByRef bAllow String sMethodName Handle hoMessage Boolean bIsFunction
        If (hoMessage = RefProc(LoadDataPage)) Begin
            Get IsControlAccessible False True to bAllow
        End
        Else Begin
            Forward Send AllowServerAction (&bAllow) sMethodName hoMessage bIsFunction
        End
    End_Procedure
        
    // This function is called when serializing the object to client. We augment it here to 
    // determine psKeyBuddy object name based on the handle set to phoKeyBuddy.
    { Visibility=Private }
    Procedure PreSerializeObject
        Handle hoObj
        String sObj
        
        Get phoKeyBuddy to hoObj
        If (hoObj <> C_WebUnresolvedObject) Begin
            Get WebObjectName of hoObj to sObj            
        End
        Set psKeyBuddy to sObj
    End_Procedure
    
    { MethodType=Event }
    Procedure OnCreateDefaultHeaderMenu
        Boolean bShowHeader bUseHeaderMenuOnWholeList
        Handle hoDefaultHeaderMenu hoChild
        
        Get pbShowHeader to bShowHeader
        Get pbUseHeaderMenuOnWholeList to bUseHeaderMenuOnWholeList
        
        Get CreateNamed of Self (RefClass(cWebContextMenu)) "oDefaultHeaderMenu" to hoDefaultHeaderMenu
        Set piWidth of hoDefaultHeaderMenu to 220
        Get CreateNamed of hoDefaultHeaderMenu (RefClass(cWebMenuColumnList)) "oColumnList" to hoChild
        Get CreateNamed of hoDefaultHeaderMenu (RefClass(cWebMenuColumnRestorer)) "oColumnRestorer" to hoChild
        Get CreateNamed of hoDefaultHeaderMenu (RefClass(cWebMenuGroupingSelector)) "oGroupingSelector" to hoChild

        If (bShowHeader and not(bUseHeaderMenuOnWholeList)) Begin
            Set peContext of hoDefaultHeaderMenu to C_WebUIContextListHead
        End
        Else Begin
            Set peContext of hoDefaultHeaderMenu to C_WebUIContextListFull
        End
        
        Set phPrivateDefaultHeaderMenu to hoDefaultHeaderMenu
    End_Procedure
    
    Procedure End_Construct_Object
        // Create the default menu if no custom was specified.
        If (pbUseCustomHeaderMenu(Self) = False) Begin
            Send OnCreateDefaultHeaderMenu
        End
        
        Forward Send End_Construct_Object
        // Publish the event methods
        WebPublishProcedure HandleProcessDataSet
        WebPublishFunction ChangeCurrentRow
        WebPublishProcedure LoadDataPage
        WebPublishProcedure ChangeSorting
        WebPublishProcedure OnSearch
        WebPublishProcedure OnRowClick
        WebPublishProcedure privateOnColumnLayoutChanged
        WebPublishProcedure privateOnGroupConfigChanged
        WebPublishProcedure privateOnGroupHeaderToggle
    End_Procedure

End_Class
