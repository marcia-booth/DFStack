    // Sent by DDOs to all DEOs whenever a DDO file/field value is changed.
    // Do nothing: This message is handled by each cWebColumn object.
    { Visibility=Private }
    Procedure File_Field_Value_Changed Integer iFile Integer iField String sValue Integer iChangeDisabled
        // Do nothing!
    End_Procedure
    
    
    // Returns the column object handle of the passed column ID
    Function GetColumnObject Integer iColumnID Returns Handle
        Handle[] hoColumnObjects
        
        Get phoColumnObjects to hoColumnObjects
        Function_Return hoColumnObjects[iColumnID]
    End_Function


    // Send this message to fire an action on the client telling it to refresh the grid.
    Procedure GridRefresh
        Boolean bFirst bLast
        tWebListData listData
        String[] asParams
        Handle hoJsonData
                
        //  We cancel previous gridRefresh client actions that might be queued before
        Send CancelClientAction "gridRefresh"
        
        // Forward call to the load data
        Get LoadData "page" "" (&bFirst) (&bLast) to listData
        WebSet pbUnOrdered to False
        
        //  Convert data to JSON
        Get Create (RefClass(cJsonObject)) to hoJsonData
        Send DataTypeToJson of hoJsonData listData

        //  Call client action with new data page
        Move bFirst         to asParams[0]
        Move bLast          to asParams[1]
        Send ClientActionEx "gridRefresh" asParams hoJsonData
        
        Send Destroy of hoJsonData
    End_Procedure

    
    // Does a empty grid refresh
    { Visibility=Private }
    Procedure EmptyGridRefresh
        String[] asParams
        tWebListData listData
        
        //  We cancel previous gridRefresh client actions that might be queued before
        Send CancelClientAction "gridRefresh"
        
        //  Call client action with empty data set
        Move True to asParams[0]
        Move True to asParams[1]
        Send ClientAction "gridRefresh" asParams listData
    End_Procedure
    
    
    // This message is sent by the client to load a page of data. Usually caused by the user 
    // scrolling to the end of the virtual list.
    Procedure LoadDataPage String sType String sStartRowID
        Boolean bFirst bLast
        tWebListData listData
        Handle hoJsonData
        String[] asParams
        
        //  Forward call to the load data
        Get LoadData sType sStartRowID (&bFirst) (&bLast) to listData
        
        //  Convert data to JSON
        Get Create (RefClass(cJsonObject)) to hoJsonData
        Send DataTypeToJson of hoJsonData listData
        
        //  Call client action with new data page
        Move sType          to asParams[0]
        Move sStartRowId    to asParams[1]
        Move bFirst         to asParams[2]
        Move bLast          to asParams[3]
        Send ClientActionEx "handleDataPage" asParams hoJsonData
        
        Send Destroy of hoJsonData
    End_Procedure


    // OnManualLoadData is False - DDO LoadData
    // Returns a set of data to be passed back to the client side grid.
    // sType - is the type of data to be loaded. Options are: 
    //         "page": returns a set of records around (above and below) the current row
    //         "first": loads the first page of data
    //         "last": loads the last page of data
    //         "next": loads the next page of data relative to the passed sStartRowID
    //         "prev": loads the previous page of data relative to the passed sStartRowID
    //         Note that these values are case sensitive.
    // sStartRowID - Is the server table's RowID to begin from when loading "next" or "prev" pages.
    // bFirst - [out] True if the returned data is the first page in the total data set.
    // bLast - [out] true if the returned data is the last page in the total data set.
    //
    // OnManualLoadData is True - Manual Load Data
    // Populates list via OnManualLoadData and sets bFirst & bLast to True
    //
    // Returns - the requested page of data.
    { Visibility=Private }
    Function LoadData String sType String sStartRowID Boolean ByRef bFirst Boolean ByRef bLast Returns tWebListData
        tWebListData listData
        Handle hoDD
        Integer iMainFile iPageSize iHalfPageSize iOrdering
        Integer iRow iCol icColumn iFile iField iLimit
        RowID riRowID
        String sValue sRowID
        Boolean bUsePageSize bReverseOrdering bDataAware bLastFound bScrollable
        Integer eDBGridType

        // Test if OnManualLoadData has been agumented. If this event returns True then we
        // will use that to populate the grid and the DDO (data-aware) grid loading will be
        // skipped.  
        Get pbDataAware to bDataAware
        Get peDbGridType to eDBGridType
        Get pbScroll to bScrollable
        
        // Data is loaded manually if the data is not-data aware or if
        // it is data aware and manual loaded.
        If (not(bDataAware) or (eDBGridType=gtManual)) Begin      
            WebGet psCurrentRowId to sRowID
                
            Send OnManualLoadData (&listData.aRows) (&sRowID) (&listData.aGroups) (&listData.aGroupHeaders)
        
            Move True to bFirst
            Move True to bLast
            WebSet psCurrentRowId to sRowID
            Function_Return listData 
        End
        
        Get ReadingServer to hoDD
        Get IndexOrder to iOrdering
        WebGet pbReverseOrdering to bReverseOrdering
        WebGet piLimitRows to iLimit

        Move False to bFirst
        Move False to bLast
        
        If (hoDD) Begin
            Move 0 to iRow
            Get piPageSize to iPageSize
            Move (eDBGridType=gtAutomatic and bScrollable and (iPageSize > 0)) to bUsePageSize
            Get Main_File of hoDD to iMainFile
            
            WebGet psCurrentRowId to sRowID    // Get the RowID of the current row
            Move (DeserializeRowID(sRowID)) to riRowID
            If (IsNullRowID(riRowID)) Begin
                // if no row id, we don't do anything. We return an empty set of rows
                // and indicate that we have all the records we can find
                Move True to bFirst
                Move True to bLast
            End
            Else Begin
                // Handle the different request "types"
                
                // "page" request type (usually initial request) returns records 
                // above and below the current row
                If (sType = "page") Begin
                    
                    // Find half a page reading backwards from the current row
                    Send ReadByRowId of hoDD iMainFile riRowID     // Read the current row
    
                    Send EstablishDDFindMode LT hoDD iOrdering bReverseOrdering
                    Send Locate_Next to hoDD
                    Move Found to bLastFound
                    Move (iPageSize / 2) to iHalfPageSize
                                        
                    While (bLastFound and (not(bUsePageSize) or (iRow < iHalfPageSize)) and (iLimit = 0 or iRow < iLimit))
                        Get LoadGridRow to listData.aRows[iRow]
                        Increment iRow
                        
                        Send Locate_Next to hoDD
                        Move Found to bLastFound    //  Store Found value since LoadGridRow triggers user events that might change the Found indicator
                    Loop
                    
                    Move (not(bLastFound) or (iLimit > 0 and iRow >= iLimit)) to bFirst              // Determine 'bFirst'
                    Move (ReverseArray(listData.aRows)) to listData.aRows  // Now reverse the array and add the rows below the current row
    
                    // load the current record
                    Send ReadByRowId of hoDD iMainFile riRowID
                    Move Found to bLastFound
                    Get LoadGridRow to listData.aRows[iRow]
                    Increment iRow
    
                    // Find the remaining records
                    Send EstablishDDFindMode GT  hoDD iOrdering bReverseOrdering
                    While ((not(bUsePageSize) or (iRow < iPageSize)) and (iLimit = 0 or iRow < iLimit))
                        Send Locate_Next to hoDD
                        Move Found to bLastFound
                        If (not(Found)) ;
                            Break
                        Get LoadGridRow to listData.aRows[iRow]
                        Increment iRow
                    Loop
                    
                    // Set the bLast flag
                    Move (not(bLastFound) or (iLimit > 0 and  iRow >= iLimit)) to bLast      
                End
                Else Begin
                    Case Begin
                        Case (sType = "first")
                            //  Load the first record
                            // NOTE: Request_Read when called during DEO Refresh (or any other DDO operation) from DDO will screw up the
                            // DDO's ability to track the array of DDO's in the DDO structure who need to be listeners to the DDO operation!
                            // Therefore make sure that this case never gets called indirectly via a DDO to DEO Refresh
                            Get ReadDDFirstRecord hoDD iOrdering bReverseOrdering to riRowID
                            Move True to bFirst
                            Case Break
                        
                        Case (sType = "last")
                            //  Load the last record
                            // NOTE: Request_Read when called during DEO Refresh (or any other DDO operation) from DDO will screw up the
                            // DDO's ability to track the array of DDO's in the DDO structure who need to be listeners to the DDO operation!
                            // Therefore make sure that this case never gets called indirectly via a DDO to DEO Refresh
                            Get ReadDDLastRecord hoDD iOrdering bReverseOrdering to riRowID
                            Move True to bLast
                            Case Break
                    
                        Case (sType = "next")
                            //  Load the start record
                            Move (DeserializeRowID(sStartRowId)) to riRowID
                            Send ReadByRowId of hoDD iMainFile riRowID
                            Send EstablishDDFindMode GT  hoDD iOrdering bReverseOrdering
                            Send Locate_Next of hoDD
                            Case Break
                    
                        Case (sType = "prev")
                            //  Load the start record
                            Move (DeserializeRowID(sStartRowId)) to riRowID
                            Send ReadByRowId of hoDD iMainFile riRowID
                            Send EstablishDDFindMode LT  hoDD iOrdering bReverseOrdering
                            Send Locate_Next of hoDD
                    Case End
                    Move Found to bLastFound
                    
                    //  Find remaining records
                    While (Found and (not(bUsePageSize) or (iRow < iPageSize)) and (iLimit = 0 or iRow < iLimit))
                        Get LoadGridRow to listData.aRows[iRow]
                        
                        Increment iRow
                        Send Locate_Next to hoDD
                        Move Found to bLastFound
                    Loop
                
                    // Set the bLast and bFirst flags
                    If (not(bLastFound) or (iLimit > 0 and  iRow >= iLimit)) Begin
                        If (sType = "next" or sType = "first") Begin
                            Move True to bLast
                        End
                        Else Begin
                            Move True to bFirst
                        End
                    End            
                End
            End
        End
        Else Begin
            //  Stop the list from trying to find records while there is no DD
            Move True to bLast
            Move True to bFirst
        End
        
        Function_Return listData
    End_Function
    
    
    // Sent by LoadData. User hook to manually populate the grid. To use this create some loop where each
    // iteration populates one row of the grid.
    // aTheRows      - [out] Array of tWebRow members to be populated. This is the grid data. 
    //                 The aValues member should contain one array member for each column, starting with
    //                 array member 1 for column one. aValues[0] should be populated with a unique RowID.
    // sCurrentRowID - [out] Set this to the unique rowID of the row you wish to become the currently 
    //                 selected row after the grid data is sent to the client.
    { MethodType=Event }
    Procedure OnManualLoadData tWebRow[] ByRef aTheRows String ByRef sCurrentRowID tWebGroupConfig[] ByRef aTheGroups tWebGroupHeader[] ByRef aTheGroupHeaders
        
    End_Procedure

    
    // Populates a single row of data.
    // This is sent by LoadData when loading data from DDO server.
    // It assumes that the global record buffers contain the grid row data that we want to display
    // in the returned tWebGridRow.s

    Function LoadGridRow Returns tWebRow
        Boolean bDataAware
        RowID riRowID
        Integer iFile iField iCol icColumn eDataType iMainFile
        String sValue
        Handle hoDD
        Handle[] aColumns
        tWebRow tRow
        
        Get pbDataAware to bDataAware
        Get Server to hoDD
        
        Get phoColumnObjects to aColumns
        Move (SizeOfArray(aColumns)) to icColumn
        Move (ResizeArray(tRow.aCells, icColumn)) to tRow.aCells
        Move -1 to tRow.iGroupHeaderIndex
        
        If (bDataAware) Begin
            Get Main_File of hoDD to iMainFile
            
            Move (GetRowID(iMainFile)) to riRowID
            Move (SerializeRowID(riRowID)) to tRow.sRowID
            
            // Iterate the grid columns
            For iCol from 0 to (icColumn-1)
                Send LoadGridCell of aColumns[iCol] (&tRow.aCells[iCol])
            Loop
        End
        Else Begin
            WebGet psCurrentRowId to tRow.sRowID
            
            //  Determine if a value was changed
            For iCol from 0 to (icColumn-1)
                Send LoadGridCell of aColumns[iCol] (&tRow.aCells[iCol])
            Loop
        End
        
        Send OnDefineRowCssClass (&tRow.sCssClassName)
        
        Function_Return tRow
    End_Function 
    
    
    // Loads the row posted from the action data into the buffer. It gets the row from a the 
    // paActionData property and updates the psValue from the colums with its values. It also sets 
    // the psCurrentRowId to the new row.
    { Visibility=Private }
    Procedure FillFromActionData
        Handle[] aColumns
        tWebRow[] aActionData
        Handle hoJson
        tWebRow tSelectRow
        Integer iCol
        String sValue
        Boolean bCol
        
        //  Get the row from the action data
        Get phoActionJsonData to hoJson
        Get JsonToDataType of hoJson to aActionData
        
        If (SizeOfArray(aActionData) > 0) Begin
            Move aActionData[0] to tSelectRow
            
            //  Update rowid
            WebSet psCurrentRowId to tSelectRow.sRowID
            
            //  Update the DEO's (columns)
            Get phoColumnObjects to aColumns
            For iCol from 0 to (SizeOfArray(aColumns) - 1)
                Get pbIsWebColumn of aColumns[iCol] to bCol
                If (bCol) Begin
                    Get ConvertFromTransport of aColumns[iCol] (RefFunc(psValue)) tSelectRow.aCells[iCol].sValue cArgStr to sValue
                    WebSet psValue of aColumns[iCol] to sValue
                    
                    WebSet pbChanged of aColumns[iCol] to False
                End
            Loop
                            
        End
        Else Begin
            Error DFERR_PROGRAM "Assert: No row data in a action data."
        End
    End_Procedure
    
    // Sent by ChangeCurrentRow. User hook to perform processing when when the client navigates the
    // focus from one row to another.
    { MethodType=Event }
    Procedure OnChangeCurrentRow String sFromRowID String sToRowID
        
    End_Procedure
    
    
