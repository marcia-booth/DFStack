Use cWebMenuItem.pkg

// Menu items for WebApp Request_Find GT
{ HelpTopic=cWebMenuFindPrevious }
Class cWebMenuFindPrevious is a cWebMenuItem
    
    Procedure Construct_Object
        Forward Send Construct_Object
        Set psCaption to C_$CaptionFindLT
        Set psCSSClass to "WebPreviousMenuItem"
        Set psToolTip to C_$ToolTipFindLT
    End_Procedure

    Procedure OnClick
        Handle hoFocus
        Get DEOControlFocusObject to hoFocus
        If hoFocus Begin
            Send Request_Find of hoFocus LT 
        End
    End_Procedure
         
End_Class 

