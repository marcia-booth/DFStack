    // Sent by DDOs to all DEOs whenever a DDO file/field value is changed.
    // If the file/filed value matches then it means this DEO is attached to
    // the same file/Field that got changed. Set the Object's synchronized 
    // psValue according to the passed value.
    { Visibility=Private }
    Procedure File_Field_Value_Changed Integer iFile Integer iField String sValue Integer iChangeDisabled
        Integer iDataFile iDataField
        Boolean bSynchingFieldDefaults
        
        // Protect agains re-entrant calls....
        If (private_pbIgnoreOnValueChanged(Self)) Begin
            Procedure_Return
        End
        
        // Do not process if this was triggered during synching of DD field defaults...
        Delegate Get SynchingFieldDefaults to bSynchingFieldDefaults
        If (bSynchingFieldDefaults) Begin
            Procedure_Return
        End
        
        Get Data_File to iDataFile

        If (iDataFile = iFile) Begin
            Get Data_Field to iDataField
            
            If (iDataField = iField) Begin
                WebSet psValue to sValue
                Send HideAllControlErrors
                If not iChangeDisabled Begin
                    WebSet pbChanged to True
                End
                Else Begin
                    WebSet pbFieldDefault to True
                End
            End
        End
    End_Procedure


    { Visibility=Private }
    Procedure File_Field_Pointer_Value_Changed Integer iFile Integer iField Pointer pValue Integer iChangeDisabled
        // called by the DD to support text fields?
        Integer iDataFile iDataField
        String sValue
        
        If (private_pbIgnoreOnValueChanged(Self)) Begin
            Procedure_Return
        End
        
        Get Data_File to iDataFile

        If (iDataFile = iFile) Begin
            Get Data_Field to iDataField
            
            If (iDataField = iField) Begin
                Move (PointerToString(pValue)) to sValue    // get the string at this pointer value
                WebSet psValue to sValue
                Send HideAllControlErrors
                
                If (not(iChangeDisabled)) Begin
                    WebSet pbChanged to True
                End
                Else Begin
                    WebSet pbFieldDefault to True
                End
            End
        End
    End_Procedure

    // Returns True if the table column is configured to be "commitable".
    // i.e. once saved should not be changed.
    { Visibility=Private }
    Function IsCommitable Returns Boolean
        Integer iFile iField iDDOOptions
        Integer iClients iClient iMain
        Handle hoServer hoOwner hoChild     
        Boolean bCommitable
        
        Get Data_File to iFile
        Get Data_Field to iField
        Get Server to hoServer
        Move False to bCommitable
        
        If (iFile and hoServer) Begin
            // the purpose is to determine if this is a commitable field....
            Get Which_Data_Set of hoServer iFile to hoOwner
            
            // if this is the main file, we check the DD_Commit flag....
            If (hoOwner = hoServer) Begin 
                Get File_Field_Options of hoServer iFile iField to iDDOOptions
                Move (IsFlagIn(DD_COMMIT, iDDOOptions)) to bCommitable
            End
            // if this is a parent, we test for a child NoSwitchIfCommitted flag
            Else If (hoOwner) Begin
                Get Data_Set_Client_Count of hoOwner to iClients
                Get Main_File of hoOwner to iMain
                Move 0 to iClient
                
                While (not(bCommitable) and iClient < iClients)
                    Get Data_Set_Client of hoOwner iClient to hoChild
                    Get ParentNoSwitchIfCommitted of hoChild iMain to bCommitable
                    Increment iClient
                Loop
            End
        End
        
        Function_Return bCommitable
    End_Function


    // If there is no data binding (no Entry_Item command) but the DEO is served by a DDO then the DEO is 
    // a calculated value. The initial data is filled by sending the OnSetCalculatedValue event. This is fired
    // whenever the DDO performs a find, clear or delete operation.
    //
    // sValue - [out] a ByRef value which this event should fill with the calculated value.
    { MethodType=Event }
    Procedure OnSetCalculatedValue String ByRef sValue
        // To be augmented by the user
    End_Procedure
    
    // call to invoke a prompt list
    // with drilldown apps, we always returns 0 for PromptObject and we 
    // always do nothing with prompt. We expect you to handle this all via
    // pbPromptButton and OnPrompt. This resolves forward reference issues and
    // in the long run is more flexible
    Procedure Prompt
        Handle hoPrompt
        Integer eStyle
        Delegate Get WebViewStyle to eStyle
        If (eStyle=wvsDesktop or eStyle=wvsDialog) Begin
            Get PromptObject to hoPrompt
            If hoPrompt Begin
                Get WebViewStyle of hoPrompt to eStyle
                If (eStyle =wvsDrillDown) Begin
                    Error DFERR_PROGRAM "Cannot Prompt to a drill down object from a desktop view"
                End
                Else Begin
                    Send Popup of hoPrompt Self
                End
            end
        End
    End_Procedure

    // called by prompt lists as part of callback to customize a list
    { MethodType=Event }
    Procedure Prompt_Callback Handle hoPrompt
    End_Procedure

    // returns PromptObject. returns phoPrompt
    Function PromptObject Returns Handle
        Handle hoPrompt
        Integer eStyle
        Delegate Get WebViewStyle to eStyle
        If (eStyle = wvsDesktop or eStyle=wvsDialog) Begin
            Get phoPrompt to hoPrompt
        End
        Function_Return hoPrompt
    End_Function    
   
    
    // Sent by DDO when there is a clear/find/save/delete.
    // This should Set all necessary web properties of the control
    // For example psValue, pbEnabled, pbChanged.
    //
    // eMode - Determines the type of DDO operation which generated this refresh message. 
    //         It may be one of the following:
    //         Mode_Clear:             Used only for DEOs attached to the DDO that was the
    //                                 "origin" of a Clear operation, (i.e., the DDO received
    //                                 the original Clear message). All other DDOs Send their 
    //                                 DEOs the refresh message passing mode_find_or_clear_set.  
    //         Mode_Find_or_Clear_Set: Used for DEOs attached to DDOs which have Found and/or cleared records.  
    //         Mode_Clear_All:         Used for DEOs attached to any DDO that participated in a clear_all operation.  
    //         Mode_Delete:            Used for DEOs attached to any DDO that performed a successful deletion. 
    //                                 DDOs that were merely updated as the result of a deletion Use Mode_Find_or_Clear_Set.  
    //         Mode_Save:              Used for DEOs attached to any DDO involved in a successful Save operation. 
    { MethodType=Event }
    Procedure Refresh Integer eMode
        Handle hoDDO
        Integer iFile iField iDDOOptions eRTS eDataType
        Boolean bActive bAppSynching bNoEnter bCommitable
        Boolean bFieldChanged
        String sValue sOldValue
        Time tTimeVal tTimeNull
        
        Forward Send Refresh eMode
        
        Get Active_State to bActive
        Get AppSynching of (Host(Self)) to bAppSynching
    
        If (bActive and not(bAppSynching)) Begin
            Get Server to hoDDO
            Get Data_File to iFile
            Get Data_Field to iField
            
            Case Begin
                Case (eMode = MODE_FIND_OR_CLEAR_SET)
                Case (eMode = MODE_CLEAR)
                Case (eMode = MODE_CLEAR_ALL)
                Case (eMode = MODE_DELETE)
                Case (eMode = MODE_SAVE)
                    If (iFile <> 0) Begin
                        Get DDRefreshTableStatus iFile to eRTS // see if this table is part of the DD's request
    
                        If (eRTS <> ddrtsNone or eMode = MODE_CLEAR_ALL) Begin
                            // Handle dynamic switching of Enabled_State. This would only happen if the
                            // file/field is commitable in the DDO....
                            // only do commit check if the field is design-time enabled
                            If (pbEnabled(Self)) Begin
                                Send SetDynamicEnabled
                            End            
                            
                            //  Do security check
                            If (not(FillDEOAllowed(Self))) Begin
                                Procedure_Return
                            End
                            
                            // Refresh should read from the global file buffers unless doing a clear and there are
                            // default values waiting in the DDO buffer....
    
                            If (eRTS = ddrtsCleared or eMode = MODE_CLEAR_ALL) Begin
                                // if the DD's field changed state is true, we must have a default value to use
                                Get File_Field_Changed_State of hoDDO iFile iField to bFieldChanged
                            End
                            Else Begin
                                Move False to bFieldChanged
                            End
            
                            If (bFieldChanged) Begin
                                // The DD buffer value has changed after a clear. That means there is a default
                                // value to read from the DDO buffer....
                                Get File_Field_Current_Value of hoDDO iFile iField to sValue
                            End
                            Else Begin
                                // In all other cases we read the value directly from the file buffer....
                                Get_Field_Value iFile iField to sValue 
                                
                                // If this was a DDO Clear and the value is "0" for a numeric field
                                // then we will Set psValue to "" instead of "0". This simulates 
                                // Windows DEO behavior.
                                If (eRTS = ddrtsCleared) Begin
                                    Get peDataType to eDataType   // If the object supports psValue it should also support peDataType. If not peDataType will get delegated to ghoWebApp and return typeASCII.
                                    
                                    If (eDataType = typeNumber and Number(sValue) = 0) Begin
                                        Move "" to sValue
                                    End
                                    
                                    If (eDataType = typeTime) Begin
                                        Move (NullDateTime()) to tTimeNull
                                        Move sValue to tTimeVal
                                        If (tTimeNull = tTimeVal) Begin
                                            Move "" to sValue
                                        End
                                    End
                                End
                            End
                        
                            Move (Rtrim(sValue)) to sValue
                           
    
                            // Set the value and changed flag web properties....
                            Send HideAllControlErrors
                            WebSet psValue to sValue
                            WebSet pbChanged to False
                            WebSet pbFieldDefault to bFieldChanged // if true, a default is set
                        End
                    End
                    Else Begin
                        WebGet psValue to sValue
                        Move sValue to sOldValue
                        Send OnSetCalculatedValue (&sValue)
                
                        // Set the value and changed flag web properties. In the case of a Clear
                        // we will unconditionally set the value/changed flag because a clear always
                        // occurs during InitForShow. During InitForShow we have no idea what is 
                        // stored on the client so therefore we must make sure that the cleared
                        // value is forced to update the client otherwise the current client value
                        // would just stay there. 
                        If (sValue <> sOldValue or eMode = MODE_CLEAR_ALL) Begin
                            WebSet psValue to sValue
                            WebSet pbChanged to False
                            WebSet pbFieldDefault to False
                        End
                    End
                    Case Break
            Case End
        End
    End_Procedure
    
    // helper function returns true if any child DDO relates to this
    { Visibility=Private } 
    Function IsConstrainingParent Handle hoDDO Returns Boolean
        Integer iClients i iFile
        Handle hoClient
        Boolean bRelates
        Get Main_File of hoDDO to iFile
        Get Data_Set_Client_Count of hoDDO to iClients
        For i from 0 to (iClients-1)
            Get Data_Set_Client of hoDDO i to hoClient
            Get IsRelatesToConstrained of hoClient iFile to bRelates
            If bRelates Begin
                Function_Return True
            End
        Loop
        Function_Return False
    End_Function
    
    // returns true if control supports prompt buttons and the prompt button
    // default property value (not webproperty) is enabled. Augmented in cWebBaseForm 
    { Visibility = Private }
    Function HasPromptButton Returns Boolean
        Function_Return False
    End_Function
    
    // this figures out if a control *should* be dynamically enabled/disabled.
    // Typically used by SetDynamicEnabled to webset pbEnabled but can be called
    // at any time.
    { Visibility=Private }
    Function IsDynamicEnabled Returns Boolean
        Handle hoServer
        Handle hoDDO
        Integer iFile iField
        Boolean bHasRecord bNoEnter bNoPut bKeyField bDisable bAutoFind bAutoFindGe 
        Boolean bCommitable bNoFind bIsReadOnly bPromptButton
        Integer iDDOOptions
    
        Get Server to hoServer
        Get Data_File to iFile        
        Get Data_Field to iField        
        If (not(hoServer) or not (iFile)) Begin
            Error DFERR_PROGRAM "Server / Data_File required"
            Function_Return True
        End
    
        Get IsViewReadOnly to bIsReadOnly
        
        If (bIsReadOnly) Begin
            Move True to bDisable                      
        End
        Else Begin
            Get Data_Set of hoServer iFile to hoDDO
            
            If (not(hoDDO)) Begin
                Error DFERR_PROGRAM "DDO for binding data_file not found"
                Function_Return True
            End
            
            // this will handle main and foreign options but not commit options
            Get File_Field_Options of hoServer iFile iField to iDDOOptions
            Move (IsFlagIn(DD_NoEnter, iDDOOptions)) to bNoEnter
            Move (IsFlagIn(DD_NoPut, iDDOOptions)) to bNoPut
            Move (IsFlagIn(DD_AUTOFIND, iDDOOptions)) to bAutoFind
            Move (IsFlagIn(DD_AUTOFIND_GE, iDDOOptions)) to bAutoFindGe
            Get HasPromptButton to bPromptButton
            
            // if main file ddo
            If (hoServer = hoDDO) Begin
                Get IsViewNoFindOnMain to bNoFind
                Get HasRecord of hoServer to bHasRecord
                Get Key_Field_State of hoServer iField to bKeyField
                If (bNoEnter) Begin
                    Move True to bDisable                      
                End
                Else If (bHasRecord and bNoFind and (bNoPut or bKeyField or bAutoFind or bAutoFindGe)) Begin
                    Move True to bDisable                      
                End
                Else If (not(bHasRecord) and bNoFind and bNoPut) Begin
                    Move True to bDisable 
                End
                Else Begin
                    Get IsCommitable to bCommitable
                    If (bCommitable) Begin
                        Get File_Field_Committed_Options of hoServer iFile iField to iDDOOptions  // possible NoPut, NoEnter additions
                        If bNoFind Begin
                            Move (iDDOOptions) to bDisable
                        End
                        Else Begin
                            Move (IsFlagIn(DD_NoEnter, iDDOOptions)) to bDisable
                        End
                    End
                End
            End
            // if parent
            Else Begin
                If (bNoEnter) Begin
                    Move True to bDisable
                End
                If (bNoPut and not(bPromptButton)) Begin
                    Move True to bDisable
                End
                Else Begin
                    Get IsViewNoFindOnConstrainedParent to bNoFind
                    If bNoFind Begin
                        Get IsConstrainingParent hoDDO to bDisable
                    End
                    If not bDisable Begin
                        Get IsCommitable to bCommitable
                        If (bCommitable) Begin
                            Get File_Field_Committed_Options of hoServer iFile iField to iDDOOptions  // possible NoPut, NoEnter additions
                            Move (IsFlagIn(DD_NoEnter, iDDOOptions)) to bDisable
                        End
                    End
                End
            End
        End
        Function_Return bDisable
    End_Function
    
    { Visibility=Private }
    Procedure SetDynamicEnabledDesktopStyle
        Handle hoServer
        Integer iFile iField iDDOOPtions
        Boolean bDisable bNoEnter bCommitable
        
        Get Server to hoServer
        Get Data_File to iFile        
        If (not(hoServer) or not (iFile)) Begin
            Procedure_Return
        End
        
        Get IsCommitable to bCommitable
        If (bCommitable) Begin
            Get Data_Field to iField
            Get File_Field_DynamicEntryOptions of hoServer iFile iField to iDDOOptions
            Move (IsFlagIn(DD_NoEnter, iDDOOptions)) to bNoEnter
            WebSet pbEnabled to (not(bNoEnter))
        End
    End_Procedure

    { Visibility=Private }
    Procedure SetDynamicEnabledDrillDownStyle
        Handle hoServer
        Integer iFile
        Boolean bDisable
        Get Server to hoServer
        Get Data_File to iFile        
        If (not(hoServer) or not (iFile)) Begin
            Procedure_Return
        End
        
        Get IsDynamicEnabled to bDisable
        WebSet pbEnabled to (not(bDisable))
    End_Procedure
    
    // this websets the enabled state based on the state of the
    // web view and the control. This is usually called during Refresh
    Procedure SetDynamicEnabled
        Integer eWebViewStyle
        Boolean bStatic
    
        Get pbEnabledStatic to bStatic
        If (not(bStatic)) Begin
            Delegate Get WebViewStyle to eWebViewStyle
            If (eWebViewStyle = wvsDrillDown) Begin
                Send SetDynamicEnabledDrillDownStyle
            End
            Else Begin
                Send SetDynamicEnabledDesktopStyle
            End
        End                
    End_Procedure

    
    Procedure Request_Find Integer eFindMode
        // Generic request find method for handling Request_Find
        // eFindMode - Can be one of... lt, le, eq, ge, gt, or it may be either Next_Record, First_Record, or Last_Record
        Integer iField iFile iMainIndex
        Handle hoServer

        Get Server to hoServer
        
        If (hoServer <> 0) Begin
            Get Data_File to iFile
            Get Data_Field to iField
            
            If (iFile > 0) Begin
                Send Item_Find to hoServer eFindMode iFile iField True False False   // Entry Update = True, Show find error = True, Deferred State = False
            End
        End
    End_Procedure
    
    // Reads the synchronized psValue and pbChanged properties and updates the DDO data binding appropriately.
    // Sent if pbDataBindable is True. Called during the AJAX Call's SynchronizeDDOs stage.
    { Visibility=Private }
    Procedure UpdateDataBinding
        Integer iField iFile
        Handle hoServer
        Boolean bChanged bDefault
        String sValue
        Boolean bNoPut bNoEnter
        Integer iDDOOptions
        
        If (not(UpdateDDAllowed(Self))) Begin
            Procedure_Return
        End
        
        Get Server to hoServer
        
        If (hoServer <> 0) Begin
            Get Data_File to iFile
            Get Data_Field to iField
            
            If (iFile > 0) Begin
                WebGet pbChanged to bChanged
                WebGet pbFieldDefault to bDefault
                
                Get File_Field_DynamicEntryOptions of hoServer iFile iField to iDDOOptions
                If (bChanged or bDefault or IsFlagIn(DD_FORCEPUT, iDDOOptions)) Begin
                    WebGet psValue to sValue
                    
                    Set private_pbIgnoreOnValueChanged to True                        // Don't process the DDO's File_Field_Value_Changed event!
                    
                    If (bChanged) ;
                        Set File_Field_Changed_Value of hoServer iFile iField to sValue   // Use File_Field because the field doesn't have to be in the server
                    Else If (IsFlagIn(DD_FORCEPUT, iDDOOptions)) ;
                        Set File_Field_Current_Value of hoServer iFile iField to sValue
                    Else ;  // if bDefault
                        Set File_Field_default_Value of hoServer iFile iField to sValue
    
                    Move (IsFlagIn(DD_NoPut, iDDOOptions)) to bNoPut
                    If (bNoPut) Begin
                        // this tells the DD that this is a DEO update on a noput field, which should only
                        // happen with foreign index fields (noput=T,noenter=F). This stops the save update
                        Set File_Field_NoPutValueChangedByDeo of hoServer iFile iField to True
                    End
                    Set private_pbIgnoreOnValueChanged to False
                End    
            End
        End
    End_Procedure
    
    { Visibility=Private }
    Function ExecFileFieldMessage Handle hMsg Returns Integer
        Integer iFile iField iResult
        Handle hoDDO
        Get Server to hoDDO
        Get Data_File  to iFile
        Get Data_Field to iField       
        If ((hoDDO <> 0) and (iFile <> 0)) Begin
            Get Exec_File_Field_Message of hoDDO iFile iField hMsg to iResult
        End
        Function_Return iResult
    End_Function
    
    // Set the field_changed_value of the the DD Field for this DEO

    Procedure DDSetChangedValue String sValue
        Integer iFile iField
        Handle hoDDO
        Get Server to hoDDO
        Get Data_File  to iFile
        Get Data_Field to iField       
        If ((hoDDO <> 0) and (iFile <> 0)) Begin
            Set File_Field_Changed_Value of hoDDO iFile iField to sValue
        End
    End_Procedure


    // send the Field_Entry message for this DEO
    
    Procedure DDFieldEntryMessage
        Integer iResult
        Get ExecFileFieldMessage (RefFunc(Field_Entry_msg)) to iResult
    End_Procedure

    // send the Field_Exit message for this DEO

    Procedure DDFieldExitMessage
        Integer iResult
        Get ExecFileFieldMessage (RefFunc(Field_Exit_msg)) to iResult
    End_Procedure
    
    // Perform a DD File Field Validate for this DEO

    Function DDFieldValidate Returns Integer
        Integer iResult iFile iField
        Handle hoDDO
        Get Server to hoDDO
        Get Data_File  to iFile
        Get Data_Field to iField       
        If ((hoDDO <> 0) and (iFile <> 0)) Begin
            Get File_Field_Validate_Field of hoDDO iFile iField to iResult
        End
        Function_Return iResult
    End_Function

    { MethodType=Event }
    Function OnValidate Returns Boolean
        Integer iResult
        Get DDFieldValidate to iResult
        Function_Return (iResult = 0)
    End_Function

    // required DD/DEO interface. This is sent from the DD during a save Request_Validate is used to allow
    // fields with DEOs bound to them to do the first validation.  
    { Visibility=Private }
    Function Validate_Items Boolean bNotFindReq Returns Integer
        Boolean bOk
        Handle hoOrigin 
        Integer iMode
        // DoAutoFind may do a DD find and reset these modes. Make sure the get restored
        Move OPERATION_MODE to iMode
        Move OPERATION_ORIGIN to hoOrigin
        Send DoAutoFind // we must make sure autofind happens before the validation
        Move iMode to OPERATION_MODE
        Move hoOrigin to OPERATION_ORIGIN
        Get OnValidate to bOk
        Function_Return (not(bOk))
    End_Function
    
    
    // performs a clear of the DD that owns the Data_File. This can be used to clear a parent
    // field in a view (e.g., salesperson in order view). This is not assigned a hot key by
    // default and it is up to the developer to use this. We also use this with autofinds that
    // allow null parents. Also note that there are no data-loss messages sent for this message
    // Added as part of null parent support.
    Procedure Request_ClearBindingTable
        Handle hoServer
        Integer iFile
        Get Server to hoServer
        Get Data_File to iFile
        If (hoServer and iFile) Begin
            Send ClearForTable of hoServer iFile
        End
    End_Procedure
    
    { Visibility=Private}
    Procedure DDSetRememberValue String sValue
        Handle hoDD hoServer
        Integer iFile iField
        Get Server to hoServer
        Get Data_File to iFile
        Get Data_Field to iField
        If (hoServer and iFile) Begin
            Get Which_Data_Set of hoServer iFile to hoDD
            Set Field_RememberedValue of hoDD iField to sValue
        End
    End_Procedure

    // Remember the DEO current value for this DEO's file/field owner DD
    Procedure DDFieldRemember
        String sValue
        WebGet psValue to sValue
        Send DDSetRememberValue sValue
    End_Procedure


    // Remember the DEO last value before clear for this DEO's file/field owner DD
    Procedure DDFieldRememberLast
        Send DDSetRememberValue DD_RememberLast
    End_Procedure

    // UnRemember his DEO's file/field owner DD
    Procedure DDFieldUnRemember
        Send DDSetRememberValue ''
    End_Procedure

    
    { MethodType=Event }
    Procedure OnChange String sNewValue String sOldValue
    End_Procedure
    
    { MethodType=Event }
    Procedure OnAutoFind
        Send DoAutoFind
    End_Procedure 
   

    // required DD/DEO interface
    { Visibility=Private }
    Procedure Update_Dependent_Items
        // do nothing
    End_Procedure
    
    
    //  Override the ShowControlError function called by the error system to show control errors. 
    //  Returns true to let the error system know that this control can show errors.
    { Visibility=Private }
    Function ShowControlError Integer iErrNum String sErrText Returns Boolean
        Boolean bInSync bRender
        
        Get IsInCallActionScope to bInSync
        If (bInSync) Begin
            Get IsControlRendered to bRender
            If (bRender) Begin
                Send ShowControlError iErrNum sErrText
                Function_Return True        
            End
        End
        
        Function_Return False
    End_Function
    
    
    //  Displays a control error in an error balloon around the control. The error number is used 
    //  as identifier to hide the error. The error will be cleared by a WebSet of psValue and the 
    //  HideControlError / HideAllControlErrors procedures and by a succesfull server-side 
    //  validation.
    // 
    //  Params:
    //      iErrNum     Error number used as identifier.
    //      sErrText    Error description.
    Procedure ShowControlError Integer iErrNum String sErrText
        String[] aParams
        
        Move iErrNum    to aParams[0]
        Move sErrText   to aParams[1]
        
        WebSet pbHasControlError to True
        Send ClientAction "showControlError" aParams
    End_Procedure
        
    
    //  Hides an error shown using ShowControlError based on its error number.
    // 
    //  Params:
    //      iErrNum     Error number used as identifier.
    Procedure HideControlError Integer iErrNum
        String[] aParams
        
        Move iErrNum    to aParams[0]
        
        Send ClientAction "hideControlError" aParams
    End_Procedure
    
    //  Hides all active control errors on this control.
    Procedure HideAllControlErrors
        Boolean bHas
        
        WebGet pbHasControlError to bHas
        
        If (bHas) Begin
            Send ClientAction "hideAllControlErrors"
            WebSet pbHasControlError to False
        End
    End_Procedure
    
    
    //  Called to determine if filling the DEO with data is allowed.
    //
    //  Params:
    //      bAllow      ByRef boolean set to false if not allowed.
    { MethodType=Event }
    Procedure AllowFillDEO Boolean ByRef bAllow
        If (bAllow) Begin
            Get IsControlAccessible False (pbNoFillIfHidden(Self)) to bAllow
        End
    End_Procedure
    
    //  Called to determine if the DEO has permission to update the Data Dictionary with new value(s).
    //
    //  Params:
    //      bAllow      ByRef boolean set to false if not allowed.
    { MethodType=Event }    
    Procedure AllowUpdateDD Boolean ByRef bAllow
        If (bAllow) Begin
            Get IsControlAccessible True (pbNoUpdateIfHidden(Self)) to bAllow
        End
    End_Procedure
    
    Procedure End_Construct_Object
        Forward Send End_Construct_Object
        
        WebPublishFunction OnValidate
        WebPublishProcedure OnChange
        WebPublishProcedure OnAutoFind
    End_Procedure
End_Class
