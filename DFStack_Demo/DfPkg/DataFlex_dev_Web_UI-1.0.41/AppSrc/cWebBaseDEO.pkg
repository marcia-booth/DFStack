Use VdfBase.pkg
Use GlobalFunctionsProcedures.pkg
Use cWebBaseControl.pkg
Use WebUIConstants.pkg
Use WebConvertClient.pkg
Use cWebView_mixin.pkg
Use findedit.pkg


// Supports:
// - User changable value.
// - Apply DD attributes (Field Options, Mask, Datatyle, length, etc.
// - DDO request interface (Request_Find, Next, Previous, First, Last, Save, Delete, Clear, etc).
//
// Not Supported:
// - Set Currency_Mask and Set Numeric_Mask interfaces are not supported. This is a confusing interface
//   as it sets several properties and it is not possible to model in the Studio. It is better and more
//   clear to just set each individual property as required psMask, peDataType and piMaxLength.
{ ClassType=Abstract }
{ DataBindable=True }
{ HelpTopic=cWebBaseDEO }
Class cWebBaseDEO is a cWebBaseControl
    
    Procedure Construct_Object
        Forward Send Construct_Object

        // these can be set via entry_item command....
        { Visibility=Private }
        Property Integer private_Data_File 0    // The binding table
        { Visibility=Private }
        Property Integer private_Data_Field 0   // The binding table column
        { Visibility=Private }
        Property Boolean private_pbIgnoreOnValueChanged False   // Used when setting Field_Changed_Value on the DDO. This prevents processing the resulting File_Field_Value_Changed event.
        { DesignTime=False }
        Property Handle phoPrompt 0
        
        // Set true to stop DEOs from web-setting pbEnabled statically based
        // on the state of the DDO
        { Category="Behavior" }
        Property Boolean pbEnabledStatic False        

        // Published Properties....
        { WebProperty=Client } 
        { EnumList="True,False,C_WebDefault"}
        { Category="Behavior" }
        Property Integer pbCapslock C_WebDefault     // True if DD_Capslock. Set by data binding.
        { WebProperty=Client } 
        { DesignTime=False }
        { Category="Behavior" }
        Property Boolean pbChanged False             // True if the value was changed on the client
        { WebProperty=Client }
        { DesignTime=False }
        { Category="Data" }
        Property Boolean pbFieldDefault False        // True if the value was set as a default value (Field_Default_Value)
        { WebProperty=Client } 
        { EnumList="True,False,C_WebDefault"}
        { Category="Data" }
        Property Integer pbRequired C_WebDefault     // True if a non-null value is required to be entered. Set by data binding.
        { WebProperty=Client } 
        { Category="Appearance" }
        { EnumList="C_WebDefault, alignLeft, alignRight, alignCenter"}
        Property Integer peAlign C_WebDefault        // Text alignment - alLeft, alRight, alCenter  ("not" set by DDO data binding. Usually the datatype will automatically determine the alignment but this property can override the automatic alignment)
        { WebProperty=Client }
        { Category="Data" } 
        { EnumList="C_WebDefault, typeASCII, typeNumber, typeDate, typeDateTime, typeTime"}
        Property Integer peDataType C_WebDefault     // Determines the data type of the control's psValue data. Set by data binding.
        { WebProperty=Client } 
        { Category="Data" }
        Property Boolean pbLimitDateRange True       // If true the client will limit dates to fit the DataFlex Date type (0001-01-01 -- 2500-01-1). Setting this to false can cause conversion errors.
        
        { WebProperty=Client } 
        { Category="Data" }
        Property Integer piMaxLength C_WebDefault    // Max number of characters that can be entered into this control. Set by data binding.
        { WebProperty=Client } 
        { Category="Data" }
        Property Integer piPrecision C_WebDefault    // Max number of numbers that can be entered after the decimal point for a numeric data type.
        { WebProperty=Client } 
        { Category="Data" }
        Property String psMask ""                    // The mask string for this control. Set by data binding.
        { WebProperty=Client } 
        { Category="Data" }
        Property String psValue ""                   // The value that is displayed in the control. Note: depending on the peDataType, the value may be formatted for data transfer, e.g. for typeDate, value is stored in universal format for transferring dates: yyyy-mm-dd.
        
        { WebProperty=Client }
        { Visibility=Private }
        Property Boolean pbHasControlError False    // Indicates it the client is showing errors, used as optimization to prevent a ClearControlErrors to be sent for every field cahnge
        
        { WebProperty=Client } 
        { Category="Server Events" }
        { EnumList="True,False,C_WebDefault"}
        Property Integer pbServerOnValidate C_WebDefault
        { WebProperty=Client } 
        { Category="Client Events" }
        Property String psClientOnValidate ""
        { WebProperty=Client } 
        { Category="Server Events" }
        Property Boolean pbServerOnChange False
        { WebProperty=Client } 
        { Category="Client Events" }
        Property String psClientOnChange ""
        
        { WebProperty=Client } 
        { Category="Server Events" }
        Property Integer pbServerOnAutoFind C_WebDefault
        { WebProperty=Client } 
        { Category="Client Events" }
        Property String psClientOnAutoFind ""
        
        { Category="Security" }
        Property Boolean pbNoUpdateIfHidden True
        { Category="Security" }
        Property Boolean pbNoFillIfHidden True

        Set pbDataBindable to True
    End_Procedure
    
    Import_Class_Protocol find_edit_mixin
    
    // Mark as DEO
    { Visibility=Private }
    Function DEO_Object Returns Boolean
        // all web objects should understand this message. Will be set True in sub-classes
        Function_Return True
    End_Function
    
    // Mark as DEO
    { Visibility=Private }
    Function DEO_Control_Object Returns Boolean
        Function_Return True
    End_Function
    
    //  Called to check if filling the DEO with data is allowed. Calls AllowFillDEO to determine.
    { Visibility=Private }
    Function FillDEOAllowed Returns Boolean
        Boolean bAllow
        
        Move True to bAllow
        Send AllowFillDEO (&bAllow)
        
        Function_Return bAllow
    End_Function
    
    //  Called to check if updating the DD with data is allowed. Calls AllowUpdateDD to determine.
    { Visibility=Private }
    Function UpdateDDAllowed Returns Boolean
        Boolean bAllow
        
        Move True to bAllow
        Send AllowUpdateDD (&bAllow)
        
        Function_Return bAllow
    End_Function
    
    
    // Sent after each DEO Object has been attached to its DDO server and had all the DDO field settings
    // applied to its published properties. We will set default values to any cWebControl properties that
    // are still unassigned...
    { Visibility=Private }
    Procedure AfterAttachDDO
        Integer iValue
        String sValue
        
        // Set default values for any unassigned properties
        Get pbServerOnAutoFind to iValue
        If (iValue = C_WebDefault) Begin
            Set pbServerOnAutoFind to False
        End

        Get pbCapslock to iValue
        If (iValue = C_WebDefault) Begin
            Set pbCapslock to False
        End

        Get pbRequired to iValue
        If (iValue = C_WebDefault) Begin
            Set pbRequired to False
        End

        Get peDataType to iValue
        If (iValue = C_WebDefault) Begin
            Set peDataType to typeASCII
        End

        Get piMaxLength to iValue
        If (iValue = C_WebDefault) Begin
            Set piMaxLength to 32768
        End

        Get piPrecision to iValue
        If (iValue = C_WebDefault) Begin
            Set piPrecision to 0
        End
        
        Get psMask to sValue
        If (sValue = String(C_WebDefault)) Begin
            Set psMask to ""
        End
    End_Procedure

    // Augmented to set all of the various properties controlled by the DDO. This is triggered when a data-bound
    // control 
    { Visibility=Private }
    Procedure Attach_Deo_To_Server
        Integer iFile iField iMaxLength iPrecision iDDOOptions iValue
        Integer eFieldType eMaskType eDataType iValidateMSG
        String sMask sLabel sTooltip sValue
        Boolean bAutoFind bAutoFindGE bCapslock bRequired bNoEnter bZeroSuppress bFindRequired
        Boolean bAutoLabelState bStatic
        Handle hoDDO hoFileDDO

        Forward Send Attach_Deo_To_Server

        Get Server to hoDDO
        Get Data_File  to iFile
        Get Data_Field to iField
        
        // If we are attached to a data binding then apply all the data dictionary attributes....
        If ((hoDDO <> 0) and (iFile <> 0)) Begin
            Get Data_Set of hoDDO iFile to hoFileDDO    // Get the file's DDO
            
            // Field Options
            Get File_Field_Options of hoDDO iFile iField to iDDOOptions
            Move (IsFlagIn(DD_AutoFind, iDDOOptions))      to bAutoFind
            Move (IsFlagIn(DD_AutoFind_GE, iDDOOptions))   to bAutoFindGE
            Move (IsFlagIn(DD_CapsLock, iDDOOptions))      to bCapslock
            Move (IsFlagIn(DD_NoEnter, iDDOOptions))       to bNoEnter
            Move (IsFlagIn(DD_Required, iDDOOptions))      to bRequired
            Move (IsFlagIn(DD_Zero_Suppress, iDDOOptions)) to bZeroSuppress
            Move (IsFlagIn(DD_FindReq, iDDOOptions))       to bFindRequired

            // Set the DEO properties....
            Get pbServerOnAutoFind to iValue
            If (iValue = C_WebDefault) Begin
                Set pbServerOnAutoFind to (bAutoFind or bAutoFindGE)
            End
            
            Get pbCapslock to iValue
            If (iValue = C_WebDefault) Begin
                Set pbCapslock to bCapslock
            End
            
            Get pbRequired to iValue
            If (iValue = C_WebDefault) Begin
                /*
                We do not set pbRequired for parent fields because this will prevent clearing of 
                the parent using autofind. We will set pbServerOnValidate to true so that the DD 
                will still give the error when tabbing out of the field (the DD also looks at the 
                changed-state to determine if it is really nessecary).
                */
                Set pbRequired to (bRequired and (hoFileDDO = hoDDO))
            End
            
            Get pbEnabledStatic to bStatic
            If (not(bStatic) and bNoEnter) Begin
                // Only disable if bNoEnter is True. Otherwise respect the current pbEnabled state...
                Set pbEnabled to False
            End
           
            // handle tool tip...
            Get psToolTip to sToolTip
            If (sToolTip = "") Begin    // only change the tooltip if it is not already set
                Get File_Field_Status_Help of hoDDO iFile iField to sToolTip
                Set psToolTip to sToolTip
            End
            
            // Set peDataType, psMask, piMaxLength, piPrecision
            Get_Attribute DF_FIELD_TYPE   of iFile iField to eFieldType    // the type of the column
            Get_Attribute DF_FIELD_LENGTH of iFile iField to iMaxLength    // max number of characters of the column
            Get File_Field_Mask_Type of hoDDO iFile iField to eMaskType    // the type specified in the DDO
            Get File_Field_Mask      of hoDDO iFile iField to sMask        // the mask string specified in the DDO

            Case Begin
                Case (eFieldType = DF_BCD)
                    Get_Attribute DF_FIELD_PRECISION of iFile iField to iPrecision
                    Move typeNumber to eDataType 
                    Case Break
                   
                Case (eFieldType = DF_DATE)
                    Move typeDate to eDataType
                    Move 10 to iMaxLength
                    Case Break
                   
                Case (eFieldType = DF_DATETIME)
                    Move typeDateTime to eDataType
                    Move 26 to iMaxLength              // should be enough for "mm/dd/yyyy hh:mm:ss.fff pm"
                    Case Break
          
                Case (eFieldType = DF_ASCII)
                Case Else
                    Move typeASCII to eDataType
                    Case Break
            Case End           

            // if the mask is blank but the field type is numeric or currency
            // we will build an automatic mask based on our default mask
            If (eMaskType = Mask_Numeric_Window or eMaskType = Mask_Currency_Window and sMask = '') Begin
                If (eMaskType = Mask_Numeric_Window) Begin
                    Move (Field_Number_Default_Mask( iFile, iField, "*")) to sMask
                End
                Else Begin
                    Move (Field_Number_Default_Mask( iFile, iField, "&curren;,*;(&curren;,*)")) to sMask
                End
            End

            // If zero-suppress add a "Z" to first char of mask only if Z is not already there.
            If (bZeroSuppress) Begin
                If ((sMask <> "") and (Left(sMask,1) <> "Z") ) Begin
                    Move ("Z" + sMask) to sMask
                End
            End
            
            // Enable server side validation if Field_Validate_msg available
            Move 0 to iValidateMSG
            If (hoDDO = hoFileDDO) Begin    // If this is not a "foreign-field"
                Get Field_Validate_msg of hoDDO iField to iValidateMSG
            End
            
            Get pbServerOnValidate to iValue
            If (iValue = C_WebDefault) Begin
                //  We enable pbServerOnValidate for required parent fields because they can't use client-side pbRequired validation
                Set pbServerOnValidate to ((iValidateMSG <> 0) or bFindRequired or (bRequired and (hoFileDDO <> hoDDO)))
            End

            // Set the DEO properties
            Get peDataType to iValue
            If (iValue = C_WebDefault) Begin
                Set peDataType to eDataType
            End

            Get piMaxLength to iValue
            If (iValue = C_WebDefault) Begin
                Set piMaxLength to iMaxLength
            End
    
            Get piPrecision to iValue
            If (iValue = C_WebDefault) Begin
                Set piPrecision to iPrecision
            End
            
            Get psMask to sValue
            If (sValue = "") Begin
                Set psMask to sMask
            End
        End
    End_Procedure

    
    // Private: Returns the autofind mode for the column's data binding.
    // (See DoAutoFind)
    { Visibility=Private }
    Function AutoFindMode Returns Integer
        Handle hoDD 
        Integer iFile iField iOpts bOn

        Get Data_File to iFile
        Get Data_Field to iField
        Get Server to hoDD
        
        If (hoDD <> 0 and iFile <> 0) Begin
            Get File_Field_Options of hoDD iFile iField to iOpts
            
            If ((iOpts iand DD_AUTOFIND_GE) = DD_AUTOFIND_GE) ;
                Function_Return amAutoFindGE
            Else If ((iOpts iand DD_AUTOFIND) = DD_AUTOFIND) ;
                Function_Return amAutoFindEQ
        End
        Function_Return amNoAutoFind
    End_Function


    // this will be sent by the Entry_item command
    { Visibility=Private }
    Procedure Bind_Data Integer iFile Integer iField
        Set Data_File to iFile
        Set Data_Field to iField
    End_Procedure
    
    
    // required DD/DEO interface
    { Visibility=Private }
    Function Checkbox_Item_State Integer iItem Returns Integer
        // not used in cWebControl
    End_Function  

    { Visibility=Private }
    Function ConvertFromTransport Handle hmGetter String sValue Integer eType Returns String
        // This function converts a Web Property value from the generic format appropriate for
        // transport. For example a data value should be converted from XML transport format 
        // for dates. e.g. European "2013-03-24" is converted into "24/03/2013"
        //                 USA      "2013-03-24" is converted into "03/24/2013"
        // The parameters sName, sValue are the property name and property value being sent from the client.
        // Returns the property value that is converted to server format.
        // For most properties this function does nothing. You can augment this function to do special
        // conversions for new WebProperties that you create.
        // See also ConvertToTransport.
        String sReturn
        Integer eDataType
        
        Forward Get ConvertFromTransport hmGetter sValue eType to sReturn

        // Test for special property "psValue"....
        If (hmGetter = RefFunc(psValue)) Begin
            // Test if the value represents a number, date or datetime. If so we must convert
            // the value into a universal format for transferring it to the client....
            Get peDataType to eDataType   // If the object supports psValue it should also support peDataType. If not peDataType will get delegated to ghoWebApp and return typeASCII.
            // Note: For efficienty we do not WebGet peDataType! In other words we do not
            // get the "synchronized copy of peDataType (if there is one). This is much more
            // efficient but it also assumes that a control's peDataType does not change 
            // dynamically. This should be OK....
            CVTLOCALIZATION ON      //  WebGet turns localization OFF, but for psValue we want it ON as this is a string property
                                    //  Note: This means that we have to keep CVTLOCALIZATION private, since we now turn it ON twice 
                                    //  while turning it OFF once. That is no problem as it never goes below 0, until other code will start using it.
            Move (ConvertFromClient(eDataType, sValue)) to sReturn
            
        End
        
        Function_Return sReturn
    End_Function

    { Visibility=Private }
    Function ConvertToTransport Handle hmGetter Variant vValue Integer iType  Returns String
        // This function converts a Web Property value into a generic format appropriate for
        // transport to the client. For example a data value should be converted into XML transport format 
        // for dates. e.g. European "24/03/2013" is converted into "2013-03-24"
        //                 USA      "03/24/2013" is converted into "2013-03-24"
        // The parameters sName, sValue are the property name and property value being sent to the client.
        // Returns the property value that is converted for transport.
        // For most properties this function does nothing. You can augment this function to do special
        // conversions for new WebProperties that you create.
        // See also ConvertFromTransport.
        String sReturn
        Integer eDataType
        
        // Test for special property "psValue"....
        If (hmGetter = RefFunc(psValue)) Begin
            // Test if the value represents a number, date or datetime. If so we must convert
            // the value into a universal format for transferring it to the client....
            Get peDataType to eDataType   // If the object supports psValue it should also support peDataType. If not peDataType will get delegated to ghoWebApp and return typeASCII.
            // Note: For efficienty we do not WebGet peDataType! In other words we do not
            // get the "synchronized copy of peDataType (if there is one). This is much more
            // efficient but it also assumes that a control's peDataType does not change 
            // dynamically. This should be OK....
            CVTLOCALIZATION ON      //  SerializeObject turns localization OFF, but for psValue we want it ON as this is a string property
                        //  Note: This means that we have to keep CVTLOCALIZATION private, since we now turn it ON twice 
                        //  while turning it OFF once. That is no problem as it never goes below 0, until other code will start using it.
            Move (ConvertToClient(eDataType, vValue)) to sReturn
        End
        Else Begin
            Forward Get ConvertToTransport hmGetter vValue iType  to sReturn
        End
        
        Function_Return sReturn
    End_Function
    
    
    // These are needed because Get Data_File and Get Data_Field expects the Item interface to be present
    // so these cannot be declared as straight properties.        
    { MethodType=Property }
    { DesignTime=False }
    { ItemParameter=1 }
    Procedure Set Data_File Integer iItem Integer iFile
        Set private_Data_File to iFile
    End_Procedure
    
    { MethodType=Property }
    { DesignTime=False }
    { ItemParameter=1 }
    Procedure Set Data_Field Integer iItem Integer iField
        Set private_Data_Field to iField
    End_Procedure
    
    { MethodType=Property }
    { DesignTime=False }
    { ItemParameter=1 }
    Function Data_File Integer iItem Returns Integer
        Function_Return (private_Data_File(Self))
    End_Function
    
    { MethodType=Property }
    { DesignTime=False }
    { ItemParameter=1 }
    Function Data_Field Integer iItem Returns Integer
        Function_Return (private_Data_Field(Self))
    End_Function

    // Performs an autofind if there is an autofind DD setting and the field is changed.
    // As soon as a succuessful autofind occurs, the field is reset.
    { Visibility=Private }
    Procedure DoAutoFind
        Integer bChanged eAuto iCur
        Handle hoDD hoServer 
        Handle[] hoDDs
        Integer iFile iField
        Boolean bAllowNull bNull bNoFindOnMain
        Integer iStat
        String sValue
        
        Get Server to hoServer
        Get Data_File  to iFile
        Get Data_Field to iField       
        
        If ((hoServer <> 0) and (iFile <> 0)) Begin
            
            // We only do an autofind check if the DD field value is changed and it is an autofind field
                    
            Get File_Field_Changed_state of hoServer iFile iField to bChanged
            If (bChanged) Begin
                Get AutoFindMode to eAuto
                If (eAuto<>0) Begin
                   Get Which_Data_Set of hoServer iFile to hoDD
                   If (hoDD and hoDD<>hoServer) Begin
                       Get Field_Current_Value of hoDD iField to sValue
                       Get IsEmptyField of hoDD iField sValue to bNull
                       // if this is an empty value this may be a null parent. See if the
                       // child that is below this parent supports null parents for this file
                       If bNull Begin
                           Send DDOServerPath of hoServer hoDD (&hoDDs) // if hoDDs returns items, 0 is hoDD and 1 is its child
                           If (SizeOfArray(hoDDs)) Begin
                              Get IsNullParentAllowed of hoDDs[1] iFile to bAllowNull                    
                           End
                       End
                   End
                   Else Begin
                        If (not(HasRecord(hoServer))) Begin
                            // if a main file autofind, see if we allow this with new records
                            Get IsViewNoFindOnMain to bNoFindOnMain
                        End
                   End
                   If (bNull and bAllowNull) Begin
                        Send Request_ClearBindingTable // if null, do a clear (essentially a find nothing)
                   End
                   Else If (bNoFindOnMain) Begin
                        // if here, this is the anti-autofind. If an autofind would succeed, it's a duplicate record error 
                        // This is used by drilldowns when a find or autofind is not appropriate because it
                        // will find a record. This should only occur with new records 
                        Clear iFile
                        // this will be a deferred (read) find.
                        Send File_Field_Find of hoServer EQ iFile iField True False True
                        Get_Attribute DF_FILE_STATUS of iFile to iStat
                        If (iStat = DF_FILE_ACTIVE) Begin
                            Send Data_set_error of hoServer iField DFERR_ENTER_VALID_REC_ID "Duplicate Record Id not allowed"
                        End
                        Else Begin
                            Send HideAllControlErrors DFERR_ENTER_VALID_REC_ID                             
                        End
                   End
                   Else Begin
                      Send File_Field_AutoFind of hoServer iFile iField (If(eAuto=amAutoFindGE, GE, EQ)) 
                   End
                End
            End
        End
    End_Procedure



