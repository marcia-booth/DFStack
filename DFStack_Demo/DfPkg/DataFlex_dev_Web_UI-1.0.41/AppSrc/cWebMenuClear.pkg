Use cWebMenuItem.pkg

// Menu items for WebApp Request_Clear
{ HelpTopic=cWebmenuClear }
Class cWebMenuClear is a cWebMenuItem
    
    Procedure Construct_Object
        Forward Send Construct_Object
        Set psCaption to C_$CaptionClear
        Set psToolTip to C_$ToolTipClear
        Set psCSSClass to "WebClearMenuItem"
    End_Procedure

    Procedure OnClick
        Handle hoFocus
        Get DEOFocusObject to hoFocus
        If hoFocus Begin
            Send Request_Clear of hoFocus
        End
    End_Procedure
         
End_Class 

