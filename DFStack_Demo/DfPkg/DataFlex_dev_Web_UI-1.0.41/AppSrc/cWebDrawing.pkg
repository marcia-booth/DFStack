    // START Positioning

    // Set the position of the item
    //
    // sId: ID of the item
    // position: The position of the item
    Procedure Position String sId tWebPoint position
        String[] asParams

        Move (ConvertToClient(typeNumber, position.fX)) to asParams[0]
        Move (ConvertToClient(typeNumber, position.fY)) to asParams[1]

        Send AddInstr sId "position" asParams
    End_Procedure

    // Set the rotation of the item
    //
    // sId: ID of the item
    // fAngle: The rotation angle in degrees, clockwise. A negative number will make the rotation go counterclockwise
    // bRotateInPlace: Determines if the item should rotate on its current spot. If this is false it will rotate around the center point of the canvas/group it is in.
    Procedure Rotation String sId Float fAngle Boolean bRotateInPlace
        String[] asParams
        
        // Restrict angle to 360
        // If it goes over, return the remainder
        Move (Mod(fAngle, 360)) to fAngle

        Move fAngle to asParams[0]
        
        If (num_arguments > 2) Begin
            Move bRotateInPlace to asParams[1]
        End

        Send AddInstr sId "rotation" asParams
    End_Procedure

    // Set the scale of the item
    //
    // sId: ID of the item
    // fScale: The scale of the item. A scale of 1 is 100%. A scale of 1.5 is 150% of the original size.
    Procedure Scaling String sId Float fScale
        String[] asParams
        
        Move (ConvertToClient(typeNumber, fScale)) to asParams[0]
        Move (ConvertToClient(typeNumber, fScale)) to asParams[1]

        Send AddInstr sId "scaling" asParams
    End_Procedure

    // Set the scale of the item both vertially and horizontally
    //
    // sId: ID of the item
    // scale: The horizontal and vertical scale. A scale of 1 is 100%. A scale of 1.5 is 150% of the original size.
    Procedure ScalingHV String sId tWebSize scale
        String[] asParams

        Move (ConvertToClient(typeNumber, scale.fWidth)) to asParams[0]
        Move (ConvertToClient(typeNumber, scale.fHeight)) to asParams[1]

        Send AddInstr sId "scaling" asParams
    End_Procedure

