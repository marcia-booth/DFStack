Use cWebBaseControl.pkg

Struct tWebDrawingInstr
    String sId
    String sType
    String[] asParams
End_Struct

Struct tWebPoint
    Float fX
    Float fY
End_Struct

Struct tWebSize
    Float fWidth
    Float fHeight
End_Struct

Struct tWebDrawingEventData
    Integer eMouseButtons
    tWebPoint tMousePosition

    tWebPoint tPosition
    Float fRotation
    tWebSize tScaling

    String sStrokeColor
    Float fStrokeWidth
    Integer iStrokeCap
    Integer iStrokeJoin
    Float fDashOffset

    String sFillColor

    String sShadowColor
    Float fShadowBlur
    tWebPoint tShadowOffset

    String sTextContent
    String sFontFamily
    Float fFontSize
    Integer eJustification
    String sFontWeight
End_Struct

Struct tWebDrawingResizetData
    Float fViewWidth
    Float fViewHeight
End_Struct

Enum_List 
    Define wdResizeModeDisabled
    Define wdResizeModeScale
    Define wdResizeModeCrop
End_Enum_List

Enum_List
    Define wdMouseButtonNone for 0
    Define wdMouseLeftButton for 1
    Define wdMouseRightButton for 2
    Define wdMouseMiddleButton for 4
End_Enum_List

Enum_List
    Define wdStrokeCapRound
    Define wdStrokeCapSquare
    Define wdStrokeCapButt
End_Enum_List

Enum_List
    Define wdStrokeJoinMiter
    Define wdStrokeJoinRound
    Define wdStrokeJoinBevel
End_Enum_List

Enum_List
    Define wdFontJustificationLeft
    Define wdFontJustificationCenter
    Define wdFontJustificationRight
End_Enum_List

Enum_List
    Define wdInteractionOnMouseDown for 1
    Define wdInteractionOnMouseUp for 2
    Define wdInteractionOnMouseEnter for 4
    Define wdInteractionOnMouseLeave for 8
    Define wdInteractionOnMouseMove for 16
    Define wdInteractionOnMouseClick for 32
    Define wdInteractionOnMouseDoubleClick for 64
    Define wdInteractionOnMouseDrag for 128
End_Enum_List

/*
Optimized storage for instruction, due to the amount of writes storing it in a property is too 
expensive (properties get copied a lot in memory).
*/
Global_Variable tWebDrawingInstr[][] gtWebDrawing_Instruction

Class cWebDrawing is a cWebBaseControl

    Procedure Construct_Object
        Forward Send Construct_Object

        // The width of the drawing
        { WebProperty = Client }
        Property Integer piDrawingWidth 0

        // The height of the drawing
        { WebProperty = Client }
        Property Integer piDrawingHeight 0
        
        // Set the mode how the component should handle resize changes. See wdResizeMode for the options.
        //
        // When wdResizeModeDisabled is selected, the drawing will show it's original size defined in piDrawingWidth and piDrawingHeight
        // When wdResizeModeScale is selected, the developer must Define a piDrawingWidth and piDrawingHeight. The canvas will try and make your drawing scale with the size of the control
        // When wdResizeModeCrop is selected, piDrawingWidth and piDrawingHeight will be ignored.
        { WebProperty = Client }
        { EnumList = "wdResizeModeDisabled,wdResizeModeScale,wdResizeModeCrop" }
        Property Integer peResizeMode wdResizeModeDisabled
        
        // Disable the default right click context menu
        { WebProperty = Client }
        Property Boolean pbNoContextMenu False
        
        { WebProperty = Client }
        Property Boolean pbZoomable False
        
        // The minimum amount of zoom.
        // Cannot go below zero
        { WebProperty = Client }
        Property Float pfMinZoom 0.125
        
        // The maximum amount of zoom.
        { WebProperty = Client }
        Property Float pfMaxZoom 4
        
        // The default amount of zoom
        { WebProperty = Client }
        Property Float pfDefaultZoom 1
        
        // Enable the OnResize Client event
        { WebProperty = Client }
        Property Boolean pbClientOnResize False

        { WebProperty = Client }
        Property Boolean pbDebugOutline False
        
        { WebProperty = Client }
        { Visibility = Private }
        Property Integer piDebugOutlineWidth 1
        
        { WebProperty = Client }
        { Visibility = Private }
        Property String psDebugOutlineColor ""
        
        { WebProperty = Client }
        Property String psCanvasBackgroundColor ""
        
        { WebProperty=Client }
        { Category=Appearance }
        Property Boolean pbShowBorder False

        { Visibility = Private }
        Property Integer piInstructionSlot -1
        
        Set pbShowLabel to False
        Set pbFillHeight to False

        Set psJSClass to "df.WebDrawing"
    End_Procedure

    Procedure ClearDrawing
        Send ClientAction "clearDrawing"
    End_Procedure

    { Visibility=Private }
    Procedure AddInstr String sId String sType String[] asParams
        tWebDrawingInstr tInstruction

        Move sId to tInstruction.sId
        Move sType to tInstruction.sType

        If (num_arguments > 2) Begin
            Move asParams to tInstruction.asParams
        End

        Send AddToInstrList tInstruction
    End_Procedure

    { Visibility=Private }
    Procedure AddToInstrList tWebDrawingInstr instruction
        tWebDrawingInstr[] atInstructions
        Integer iNextIndex
        
        If (piInstructionSlot(Self) < 0) ;
            Set piInstructionSlot to (SizeOfArray(gtWebDrawing_Instruction))

        Move instruction to gtWebDrawing_Instruction[piInstructionSlot(Self)][-1]
    End_Procedure

    // Put two floats in a tWebPoint struct
    //
    // fX: The x value
    // fY: The y value
    // Returns: tWebPoint
    Function XYPoint Float fX Float fY Returns tWebPoint
        tWebPoint point

        Move fX to point.fX
        Move fY to point.fY

        Function_Return point
    End_Function

    // Put two floats in a tWebSize struct
    Function WHSize Float fWidth Float fHeight Returns tWebSize
        tWebSize size

        Move fWidth to size.fWidth
        Move fHeight to size.fHeight

        Function_Return size
    End_Function

    // Convert a clColor to a hex value
    // Taken and adapted from Convetions lib
    //
    // iColor: The cl Color value
    //
    // Returns: HTML HEX color value as a string
    Function GDIColorToHex Integer iColor Returns String
        String sResult
        Repeat
            Move (sResult + Mid ("0123456789ABCDEF", 1, ((iColor iand |CI$0F) + 1))) to sResult
            Move (iColor / |CI$10) to iColor
        Until (iColor = 0)

        // Fill remaining
        While (Length(sResult) < 6)
            Move (sResult + "0") to sResult
        Loop

        // Prepend hash symbol
        Move ("#" + sResult) to sResult

        Function_Return sResult
    End_Function

    // START Create paths

    // Draw a rectangle
    //
    // sId: ID of the item
    // position: Position
    // size: Size
    // tCorner: Corner size
    Procedure CreateRectangle String sId tWebPoint position tWebSize size Float fCornerRadius
        String[] asParams

        Move (ConvertToClient(typeNumber, position.fX)) to asParams[0]
        Move (ConvertToClient(typeNumber, position.fY)) to asParams[1]

        Move (ConvertToClient(typeNumber, size.fWidth)) to asParams[2]
        Move (ConvertToClient(typeNumber, size.fHeight)) to asParams[3]

        // Optional corner size
        If (num_arguments > 3) Begin
            Move fCornerRadius to asParams[4]
        End

        Send AddInstr sId "create-rectangle" asParams
    End_Procedure

    // Draw a circle
    //
    // sId: ID of the item
    // centerPosition: The center position
    // fRadius: Radius of the circle
    Procedure CreateCircle String sId tWebPoint centerPosition Float fRadius
        String[] asParams

        Move (ConvertToClient(typeNumber, centerPosition.fX)) to asParams[0]
        Move (ConvertToClient(typeNumber, centerPosition.fY)) to asParams[1]
        Move (ConvertToClient(typeNumber, fRadius)) to asParams[2]

        Send AddInstr sId "create-circle" asParams
    End_Procedure

    // Draw an ellipse
    //
    // sId: ID of the item
    // centerPosition: Top left position of the ellipse
    // size: Size of the ellipse
    Procedure CreateEllipse String sId tWebPoint centerPosition tWebSize size
        String[] asParams

        Move (ConvertToClient(typeNumber, centerPosition.fX)) to asParams[0]
        Move (ConvertToClient(typeNumber, centerPosition.fY)) to asParams[1]

        Move (ConvertToClient(typeNumber, size.fWidth))  to asParams[2]
        Move (ConvertToClient(typeNumber, size.fHeight)) to asParams[3]

        Send AddInstr sId "create-ellipse" asParams
    End_Procedure

    // Start drawing a path
    //
    // sId: ID of the item
    Procedure CreatePath String sId
        Send AddInstr sId "create-path"
    End_Procedure
    
    // Create a line from two points
    //
    // sId: ID of the item
    // firstPosition: The first position of the line
    // secondPosition: The second position of the line
    Procedure CreateLine String sId tWebPoint firstPosition tWebPoint secondPosition
        String[] asParams
        
        Move (ConvertToClient(typeNumber, firstPosition.fX)) to asParams[0]
        Move (ConvertToClient(typeNumber, firstPosition.fY)) to asParams[1]
        
        Move (ConvertToClient(typeNumber, secondPosition.fX)) to asParams[2]
        Move (ConvertToClient(typeNumber, secondPosition.fY)) to asParams[3]
        
        Send AddInstr sId "create-line" asParams
    End_Procedure

    // Draw text
    //
    // sId: ID of the item
    // tPosition: The position of the item
    // sContent: The text content
    // sFontFamily: The Font family
    // fFontSize: The size of the font
    // eJustification: Optional, The justification of the text, see wdFontJustification
    // sFontWeight: Optional, The amount of weight of a font in as a CSS property
    // sTextDecoration: Optional, the type of decoration used for text. For example, underline and overline.
    Procedure CreateText String sId tWebPoint position String sContent String sFontFamily Float fFontSize Integer eJustification String sFontWeight String sTextDecoration
        String[] asParams

        Move (ConvertToClient(typeNumber, position.fX)) to asParams[0]
        Move (ConvertToClient(typeNumber, position.fY)) to asParams[1]
        Move sContent to asParams[2]
        Move sFontFamily to asParams[3]
        Move (ConvertToClient(typeNumber, fFontSize)) to asParams[4]

        If (num_arguments > 5) Begin
            Move eJustification to asParams[5]
        End

        If (num_arguments > 6) Begin
            Move sFontWeight to asParams[6]
        End
        
        If (num_arguments > 7) Begin
            Move sTextDecoration to asParams[7]
        End

        Send AddInstr sId "create-text" asParams
    End_Procedure

    // END Create paths

    // START Create Raster/SVG

    // Put an image on the drawing
    //
    // sId: ID of the item
    // sPath: Path to the image file, relative to the AppHtml folder
    // firstPosition: First position of the image. This will be the center position
    //                if secondPosition is not filled in
    // secondPosition: Optional, The second point of the image. It will scale the image
    //                 between the two points.
    Procedure CreateImage String sId String sPath tWebPoint firstPosition tWebPoint secondPosition
        String[] asParams

        Move sPath to asParams[0]

        Move (ConvertToClient(typeNumber, firstPosition.fX)) to asParams[1]
        Move (ConvertToClient(typeNumber, firstPosition.fY)) to asParams[2]

        If (num_arguments > 3) Begin
            Move (ConvertToClient(typeNumber, secondPosition.fX)) to asParams[3]
            Move (ConvertToClient(typeNumber, secondPosition.fY)) to asParams[4]
        End

        Send AddInstr sId "create-image" asParams
    End_Procedure

    // Put an SVG on the drawing
    //
    // sId: ID of the item
    // sPath: Path to the image file, relative to the AppHtml folder
    // firstPosition: First position of the image. This will be the center position
    //                if secondPosition is not filled in
    // secondPosition: Optional, The second point of the image. It will scale the image
    //                 between the two points.
    Procedure CreateSVG String sId String sPath tWebPoint firstPosition tWebPoint secondPosition
        String[] asParams

        Move sPath to asParams[0]

        Move (ConvertToClient(typeNumber, firstPosition.fX)) to asParams[1]
        Move (ConvertToClient(typeNumber, firstPosition.fY)) to asParams[2]

        If (num_arguments > 3) Begin
            Move secondPosition.fX to asParams[3]
            Move secondPosition.fY to asParams[4]
        End

        Send AddInstr sId "create-svg" asParams
    End_Procedure

    // END Create Raster/SVG

