        Move (ConvertToClient(typeNumber, position.fX)) to asParams[0]
        Move (ConvertToClient(typeNumber, position.fY)) to asParams[1]

        Send AddInstr sId "add" asParams
    End_Procedure

    // Create a new subpath
    //
    // sId: ID of the item
