    // Create a curved line between two points
    //
    // sId: ID of the item
    // troughPoint: The point where the angle leans towards
    // toPoint: The point the line should end
    Procedure QuadraticCurveTo String sId tWebPoint troughPoint tWebPoint toPoint
        String[] asParams

        Move (ConvertToClient(typeNumber, troughPoint.fX)) to asParams[0]
        Move (ConvertToClient(typeNumber, troughPoint.fY)) to asParams[1]
        Move (ConvertToClient(typeNumber, toPoint.fX)) to asParams[2]
        Move (ConvertToClient(typeNumber, toPoint.fY)) to asParams[3]

        Send AddInstr sId "quadraticCurveTo" asParams
    End_Procedure

