    // START Client events
    
    { Visibility = Private }
    Procedure ReceiveEventData String sEventName String sId
        Handle hoJson
        tWebDrawingEventData eventData

        Get phoActionJsonData to hoJson
        Get JsonToDataType of hoJson to eventData
        
        Case Begin
            Case (sEventName = "HandleMouseClick")
                Send OnMouseClick sId eventData
                Case Break
            Case (sEventName = "HandleMouseDoubleClick")
                Send OnMouseDoubleClick sId eventData
                Case Break
            Case (sEventName = "HandleMouseUp")
                Send OnMouseUp sId eventData
                Case Break
            Case (sEventName = "HandleMouseDown")
                Send OnMouseDown sId eventData
                Case Break
            Case (sEventName = "HandleMouseDrag")
                Send OnMouseDrag sId eventData
                Case Break
            Case (sEventName = "HandleMouseEnter")
                Send OnMouseEnter sId eventData
                Case Break
            Case (sEventName = "HandleMouseLeave")
                Send OnMouseMove sId eventData
                Case Break
            Case (sEventName = "HandleMouseMove")
                Send OnMouseMove sId eventData
                Case Break
        Case End
        
        Send UpdateDrawing
    End_Procedure

    { Visibility = Private }
    Procedure HandleResize
        Handle hoJson
        tWebDrawingResizetData resizeEventData

        Get phoActionJsonData to hoJson
        Get JsonToDataType of hoJson to resizeEventData

        Send OnResize resizeEventData
    End_Procedure

    // END Client events

    // START Event handlers

    // Receive event when the mouse has been pressed down
    //
    // sId: ID of the item clicked
    // eventData: The event data
    { MethodType = Event }
    Procedure OnMouseDown String sId tWebDrawingEventData eventData
        //
    End_Procedure

    // Receive event when the mouse has been released
    //
    // sId: ID of the item released
    // eventData: The event data
    { MethodType = Event }
    Procedure OnMouseUp String sId tWebDrawingEventData eventData
        //
    End_Procedure

    // Receive event when the mouse has entered the shape
    //
    // sId: ID of the item entered
    // eventData: The event data
    { MethodType = Event }
    Procedure OnMouseEnter String sId tWebDrawingEventData eventData
        //
    End_Procedure

    // Receive event when the mouse has left the shape
    //
    // sId: ID of the item left
    // eventData: The event data
    { MethodType = Event }
    Procedure OnMouseLeave String sId tWebDrawingEventData eventData
        //
    End_Procedure

    // Receive event when the mouse moved over a shape
    //
    // sId: ID of the item moved over
    // eventData: The event data
    { MethodType = Event }
    Procedure OnMouseMove String sId tWebDrawingEventData eventData
        //
    End_Procedure

    // Receive event when the mouse has clicked on a shape
    //
    // sId: ID of the item clicked
    // eventData: The event data
    { MethodType = Event }
    Procedure OnMouseClick String sId tWebDrawingEventData eventData
        //
    End_Procedure

    // Receive event when the mouse has double clicked on a shape
    //
    // sId: ID of the item double clicked
    // eventData: The event data
    { MethodType = Event }
    Procedure OnMouseDoubleClick String sId tWebDrawingEventData eventData
        //
    End_Procedure

    // Receive event when the mouse dragged a shape
    //
    // sId: ID of the item dragged
    // eventData: The event data
    { MethodType = Event }
    Procedure OnMouseDrag String sId tWebDrawingEventData eventData
        //
    End_Procedure

    // Receive event when the drawing has been resized
    //
    // resizeEventData: The Resize event data
    { MethodType = Event }
    Procedure OnResize tWebDrawingResizetData resizeEventData
        //
    End_Procedure
    
    // Receive image data
    //
    // sDataBase64: PNG Data in Base64
    { MethodType = Event }
    Procedure OnReceiveImage String sDataBase64
        //
    End_Procedure
    
    // Receive the JSON data of the canvas
    //
    // sJsonData: The data as a Json string
    { MethodType = Event }
    Procedure OnReceiveJsonExport String sJsonData
        //
    End_Procedure

    // END Event handlers

    Procedure UpdateDrawing
        String[] asParams
        tWebDrawingInstr[] tInstructions tEmptyInstructions
        
        If (piInstructionSlot(Self) >= 0) Begin
            Send ClientAction "updateInstructions" asParams gtWebDrawing_Instruction[piInstructionSlot(Self)]
            Move tEmptyInstructions to gtWebDrawing_Instruction[piInstructionSlot(Self)]
            Set piInstructionSlot to -1
        End
    End_Procedure
    
    Procedure ExportDrawingPNG
        Send ClientAction "exportDrawingToImage"
    End_Procedure
    
    Procedure ExportDrawingJsonData
        Send ClientAction "exportDrawingDataToJSON"
    End_Procedure
    
    Procedure ImportDrawingJsonData String sJsonData
        String[] asInputData
        Move sJsonData to asInputData[0]
        
        Send ClientAction "importDrawingFromJSON" asInputData
    End_Procedure

    Procedure End_Construct_Object
        Forward Send End_Construct_Object

        WebPublishProcedure ReceiveEventData

        WebPublishProcedure HandleResize
        
        WebPublishProcedure OnReceiveImage
        WebPublishProcedure OnReceiveJsonExport
    End_Procedure

End_Class
