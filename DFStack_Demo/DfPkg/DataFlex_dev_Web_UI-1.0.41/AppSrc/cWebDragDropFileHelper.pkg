Use cWebDragDropHelper.pkg
Use cWebFileUploadMixin.pkg

Class cWebDragDropFileHelper is a cWebDragDropHelper
    Import_Class_Protocol cWebFileUploadMixin
    
    Procedure Construct_Object
        Forward Send Construct_Object
        
        { WebProperty=Client }
        { Category="Behavior" } 
        Property Boolean pbMultiFile True
        
        Set psJSClass to "df.WebDragDropFileHelper"
        
        Send DefineWebFileUploadMixin
    End_Procedure
    
    // This is called to trigger the OnFileDrop event.
    //
    // Published!
    { Visibility=Private }
    Function FileDrop String sDropTargetName Integer eDropPosition Returns String
        String[][] aFiles 
        String[][] aResult
        String sPath sData
        Integer iFile iTo
        Handle hoJsonObj hoJsonDragData hoJsonDropData hoDropTarget hoJson

        //  Parse JSON
        Get phoActionJsonData to hoJson
        
        Get Member of hoJson "DragData" to hoJsonDragData // <-- Contains files array
        Get Member of hoJson "DropData" to hoJsonDropData // Drop data based on target
        
        Get WebObjectByName sDropTargetName to hoDropTarget
        
        If (hoDropTarget <> C_WebUnresolvedObject) Begin
            Set phoJsonDropData of hoDropTarget to hoJsonDropData
        End
        
        // Extract files
        Get JsonToDataType of hoJsonDragData to aFiles
        
        Move (SizeOfArray(aFiles) - 1) to iTo
        
        For iFile from 0 to iTo
            Move aFiles[iFile][0] to aResult[iFile][0]
            
            Get OnFileDrop aFiles[iFile][1] aFiles[iFile][2] aFiles[iFile][3] hoDropTarget eDropPosition to sPath
            
            If (sPath <> "") Begin
                Get FileUploadKey of (ResourceManager(Self)) sPath to aResult[iFile][1]
            End
            Else Begin
                Move "" to aResult[iFile][1]
            End
        Loop
        
        //  Return upload paths to client
        Get Create (RefClass(cJsonObject)) to hoJsonObj
        Send DataTypeToJson of hoJsonObj aResult
        Get Stringify of hoJsonObj to sData
        Send Destroy of hoJsonObj
        
        Function_Return sData
        
        //  Cleanup
        If (hoDropTarget <> C_WebUnresolvedObject) Begin
            Set phoJsonDropData of hoDropTarget to C_WebUnresolvedObject
        End
    End_Function
    
    // User augmented, can be used to respond to a file drop and should return the path to store the file
    {MethodType = Event}
    Function OnFileDrop String sFileName BigInt iBytes String sMime Handle hoDropTarget WebDropPosition eDropPosition Returns String
        Function_Return ""
    End_Function

    Procedure End_Construct_Object
        Forward Send End_Construct_Object
        
        // Since we have our own End_Construct_Object, we need to manually publish the methods from the cWebFileUploadMixin
        Send PublishFileUploadMethods
        WebPublishFunction FileDrop
    End_Procedure

End_Class