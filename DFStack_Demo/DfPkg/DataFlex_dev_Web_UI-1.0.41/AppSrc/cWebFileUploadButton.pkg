Use cWebBaseFileUpload.pkg

{ OverrideProperty=pbShowDialog Visibility=Private }
{ OverrideProperty=pbShowLabel InitialValue=False }
{ HelpTopic=cWebFileUploadButton }
{ DesignerJSClass=df.WebFileUploadButton }
Class cWebFileUploadButton is a cWebBaseFileUpload
    
    Procedure Construct_Object
        Forward Send Construct_Object
        
        { WebProperty=Client }
        { Category="Behavior" }
        Property Boolean pbMultiFile True
        
        { WebProperty=Client }
        { Category="Behavior" }
        Property Boolean pbNotifyIndividualFile False
        
        { WebProperty=Client }
        { Category="Appearance" }
        Property String psCaption "Select file(s)"
        
        { WebProperty=Client } 
        { Category="Appearance" }         
        { EnumList="C_WebDefault, alignLeft, alignRight, alignCenter"}
        Property Integer peAlign C_WebDefault    
        
        
        Set pbShowLabel to False
        Set psJSClass to "df.WebFileUploadButton"
    End_Procedure

End_Class
